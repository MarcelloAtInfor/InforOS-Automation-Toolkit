          </Assign.To>
          <Assign.Value>
            <InArgument x:TypeArguments="x:String">[If(String.IsNullOrWhiteSpace(exceptionStackTrace), "N/A", If(exceptionStackTrace.Length > 500, exceptionStackTrace.Substring(0, 500).Replace("""", "'").Replace(Convert.ToChar(10).ToString(), " ").Replace(Convert.ToChar(13).ToString(), " ") + "...", exceptionStackTrace.Replace("""", "'").Replace(Convert.ToChar(10).ToString(), " ").Replace(Convert.ToChar(13).ToString(), " ")))]</InArgument>
