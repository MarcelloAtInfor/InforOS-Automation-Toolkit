          </Assign.To>
          <Assign.Value>
            <InArgument x:TypeArguments="x:String">[If(String.IsNullOrWhiteSpace(exceptionMessage), "Unknown error", exceptionMessage.Replace("""", "'").Replace(Convert.ToChar(10).ToString(), " ").Replace(Convert.ToChar(13).ToString(), " "))]</InArgument>
