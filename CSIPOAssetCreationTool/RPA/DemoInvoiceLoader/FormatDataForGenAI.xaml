  <TryCatch DisplayName="TryCatch Format Data" sap2010:WorkflowViewState.IdRef="TryCatch_Main">
    <TryCatch.Variables>
      <Variable x:TypeArguments="x:String" Name="vendorName" />
      <Variable x:TypeArguments="x:String" Name="vendorAddress" />
      <Variable x:TypeArguments="x:String" Name="vendorPhone" />
      <Variable x:TypeArguments="x:String" Name="vendorEmail" />
      <Variable x:TypeArguments="x:String" Name="poNumber" />
      <Variable x:TypeArguments="x:String" Name="orderDate" />
      <Variable x:TypeArguments="x:String" Name="warehouse" />
      <Variable x:TypeArguments="x:String" Name="terms" />
      <Variable x:TypeArguments="njl:JArray" Name="extractionData" />
      <Variable x:TypeArguments="njl:JArray" Name="tableRows" />
      <Variable x:TypeArguments="njl:JToken" Name="tempToken" />
      <Variable x:TypeArguments="x:String" Name="lineItemsJson" />
      <Variable x:TypeArguments="x:Int32" Name="lineIndex" />
      <Variable x:TypeArguments="njl:JToken" Name="currentRow" />
      <Variable x:TypeArguments="x:String" Name="lineItemCode" />
