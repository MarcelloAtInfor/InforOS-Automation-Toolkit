      <Variable x:TypeArguments="x:String" Name="idoLoadError" />
      <Variable x:TypeArguments="scg:IDictionary(x:String, x:Object)" Name="idoLoadOutputDict" />
    </Sequence.Variables>
    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[searchStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["PENDING"]</InArgument></Assign.Value></Assign>
    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[searchErrorMessage]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[""]</InArgument></Assign.Value></Assign>
    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[queryFilter]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["PoNum = '"+If(purchaseOrderNumber Is Nothing, "", purchaseOrderNumber.Replace("'", "''").Trim().ToUpper())+"'"]</InArgument></Assign.Value></Assign>
    <iaw:InvokeWorkflow Arguments="[New Dictionary(Of String, Object) From {{&quot;tenantURL&quot;,tenantURL},{&quot;site&quot;,site},{&quot;idoName&quot;,&quot;SLPOs&quot;},{&quot;properties&quot;,&quot;PoNum,VendNum,TermsCode,Stat,Type,Whse,PoCurrCode,SalesTaxT,_ItemId&quot;},{&quot;filter&quot;,queryFilter},{&quot;orderBy&quot;,&quot;PoNum ASC&quot;},{&quot;recordCap&quot;,&quot;1&quot;},{&quot;logFile&quot;,logFile}}]" ContinueOnError="False" DisplayName="Execute PO Load" sap2010:WorkflowViewState.IdRef="InvokeWorkflow_1" OutputArguments="[idoLoadOutputDict]" ResponseCode="{x:Null}" WorkflowFile="[projectPath+&quot;\ExecuteIdoLoad.xaml&quot;]" />
    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[idoLoadResponse]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(idoLoadOutputDict IsNot Nothing AndAlso idoLoadOutputDict.ContainsKey("responseJson"), idoLoadOutputDict("responseJson").ToString(), "")]</InArgument></Assign.Value></Assign>
    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[idoLoadStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(idoLoadOutputDict IsNot Nothing AndAlso idoLoadOutputDict.ContainsKey("operationStatus"), idoLoadOutputDict("operationStatus").ToString(), "FAILED")]</InArgument></Assign.Value></Assign>
    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[idoLoadError]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(idoLoadOutputDict IsNot Nothing AndAlso idoLoadOutputDict.ContainsKey("errorMessage"), idoLoadOutputDict("errorMessage").ToString(), "")]</InArgument></Assign.Value></Assign>
    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[poResponseJson]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[idoLoadResponse]</InArgument></Assign.Value></Assign>
    <ias:Append_Line ErrorCode="{x:Null}" ContinueOnError="True" DisplayName="Log PO Search Summary" sap2010:WorkflowViewState.IdRef="Append_Line_1" Line="[System.Environment.NewLine+&quot;  SearchPurchaseOrder:&quot;+System.Environment.NewLine+&quot;    Filter: &quot;+queryFilter+System.Environment.NewLine+&quot;    Status: &quot;+idoLoadStatus+If(idoLoadError.Length &gt; 0, System.Environment.NewLine+&quot;    Error: &quot;+idoLoadError, &quot;&quot;)]" Source="[logFile]" />
    <If Condition="[idoLoadStatus = &quot;SUCCESS&quot;]">
      <If.Then>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[searchStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["SUCCESS"]</InArgument></Assign.Value></Assign>
