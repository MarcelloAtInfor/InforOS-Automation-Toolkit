                    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[claimedDocumentPathLocal]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(claimOutput IsNot Nothing AndAlso claimOutput.ContainsKey("claimedDocumentPath") AndAlso claimOutput("claimedDocumentPath") IsNot Nothing, claimOutput("claimedDocumentPath").ToString(), childDocumentPath)]</InArgument></Assign.Value></Assign>
                    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[claimedJsonPathLocal]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(claimOutput IsNot Nothing AndAlso claimOutput.ContainsKey("claimedJsonPath") AndAlso claimOutput("claimedJsonPath") IsNot Nothing, claimOutput("claimedJsonPath").ToString(), childJsonPath)]</InArgument></Assign.Value></Assign>

                    <If Condition="[claimStatusLocal = &quot;SUCCESS&quot;]">
                      <If.Then>
                        <Sequence>
                          <iaw:InvokeWorkflow ResponseCode="{x:Null}" Arguments="[New Dictionary(Of String, Object) From {{&quot;projectPath&quot;,projectPath},{&quot;tenantURL&quot;,tenantURL},{&quot;site&quot;,site},{&quot;documentPath&quot;,claimedDocumentPathLocal},{&quot;inputFolderPath&quot;,&quot;&quot;},{&quot;useFormattedInvoiceInput&quot;,True},{&quot;rawOcrJson&quot;,&quot;&quot;},{&quot;rawOcrJsonPath&quot;,&quot;&quot;},{&quot;sourceDocumentName&quot;,childSourceName},{&quot;proposedVendorNumber&quot;,&quot;&quot;},{&quot;purchaseOrderNumber&quot;,&quot;&quot;},{&quot;warehouse&quot;,warehouse},{&quot;termsCode&quot;,terms},{&quot;recipientUserId&quot;,recipientUserId},{&quot;enableNotifications&quot;,enableNotifications},{&quot;logFile&quot;,logFile}}]" ContinueOnError="False" DisplayName="Process Single Document" OutputArguments="[childOutput]" WorkflowFile="[projectPath+&quot;\SingleDocumentController.xaml&quot;]" />
                          <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[childStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(childOutput IsNot Nothing AndAlso childOutput.ContainsKey("resultOverallStatus") AndAlso childOutput("resultOverallStatus") IsNot Nothing, childOutput("resultOverallStatus").ToString(), "FAILED")]</InArgument></Assign.Value></Assign>
                          <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[childSummaryJson]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(childOutput IsNot Nothing AndAlso childOutput.ContainsKey("resultSummaryJson") AndAlso childOutput("resultSummaryJson") IsNot Nothing, childOutput("resultSummaryJson").ToString(), "{}")]</InArgument></Assign.Value></Assign>
                          <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[childError]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(childOutput IsNot Nothing AndAlso childOutput.ContainsKey("resultErrorMessage") AndAlso childOutput("resultErrorMessage") IsNot Nothing, childOutput("resultErrorMessage").ToString(), "")]</InArgument></Assign.Value></Assign>
                        </Sequence>
                      </If.Then>
                      <If.Else>
                        <Sequence>
                          <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[childStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["FAILED"]</InArgument></Assign.Value></Assign>
                          <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[childSummaryJson]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["{}"]</InArgument></Assign.Value></Assign>
                          <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[childError]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[claimErrorLocal]</InArgument></Assign.Value></Assign>
                        </Sequence>
                      </If.Else>
                    </If>

                    <iaw:InvokeWorkflow ResponseCode="{x:Null}" Arguments="[New Dictionary(Of String, Object) From {{&quot;inputFolderPath&quot;,inputFolderPath},{&quot;claimedDocumentPath&quot;,claimedDocumentPathLocal},{&quot;claimedJsonPath&quot;,claimedJsonPathLocal},{&quot;processingStatus&quot;,childStatus},{&quot;logFile&quot;,logFile}}]" ContinueOnError="False" DisplayName="Finalize Batch Document" OutputArguments="[finalizeOutput]" WorkflowFile="[projectPath+&quot;\FinalizeBatchDocument.xaml&quot;]" />
                    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[finalizeStatusLocal]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(finalizeOutput IsNot Nothing AndAlso finalizeOutput.ContainsKey("finalizeStatus") AndAlso finalizeOutput("finalizeStatus") IsNot Nothing, finalizeOutput("finalizeStatus").ToString(), "FAILED")]</InArgument></Assign.Value></Assign>
                    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[finalizeErrorLocal]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(finalizeOutput IsNot Nothing AndAlso finalizeOutput.ContainsKey("finalizeErrorMessage") AndAlso finalizeOutput("finalizeErrorMessage") IsNot Nothing, finalizeOutput("finalizeErrorMessage").ToString(), "")]</InArgument></Assign.Value></Assign>
                    <If Condition="[finalizeStatusLocal &lt;&gt; &quot;SUCCESS&quot;]">
                      <If.Then>
                        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[childError]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(String.IsNullOrWhiteSpace(childError), finalizeErrorLocal, childError + " | Finalize: " + finalizeErrorLocal)]</InArgument></Assign.Value></Assign>
                      </If.Then>
                    </If>

                    <Assign><Assign.To><OutArgument x:TypeArguments="x:Int32">[processedCount]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:Int32">[processedCount + 1]</InArgument></Assign.Value></Assign>
                    <If Condition="[childStatus = &quot;SUCCESS&quot;]">
                      <If.Then>
                        <Assign><Assign.To><OutArgument x:TypeArguments="x:Int32">[successCount]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:Int32">[successCount + 1]</InArgument></Assign.Value></Assign>
