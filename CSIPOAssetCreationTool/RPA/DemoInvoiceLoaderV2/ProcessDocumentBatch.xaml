                    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[resultsFragments]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[resultsFragments + If(String.IsNullOrWhiteSpace(resultsFragments), "", ",") + "{""sourceDocumentName"":""" + childSourceName.Replace("""","'") + """,""status"":""" + childStatus.Replace("""","") + """,""errorMessage"":""" + childError.Replace("""","'") + """,""summaryJson"":" + childSummaryJson + "}"]</InArgument></Assign.Value></Assign>
                  </Sequence>
                </ActivityAction>
              </ForEach>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[batchResultsJson]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["[" + resultsFragments + "]"]</InArgument></Assign.Value></Assign>
            </Sequence>
          </If.Then>
          <If.Else>
            <Sequence>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:Int32">[processedCount]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:Int32">[0]</InArgument></Assign.Value></Assign>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:Int32">[successCount]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:Int32">[0]</InArgument></Assign.Value></Assign>
