        <iaw:InvokeWorkflow ResponseCode="{x:Null}" Arguments="[New Dictionary(Of String, Object) From {{&quot;inputFolderPath&quot;,inputFolderPath},{&quot;logFile&quot;,logFile}}]" ContinueOnError="False" DisplayName="Ensure Batch Folders" OutputArguments="[ensureOutput]" WorkflowFile="[projectPath+&quot;\EnsureBatchFolders.xaml&quot;]" />
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[ensureStatusLocal]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(ensureOutput IsNot Nothing AndAlso ensureOutput.ContainsKey("ensureStatus") AndAlso ensureOutput("ensureStatus") IsNot Nothing, ensureOutput("ensureStatus").ToString(), "FAILED")]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[ensureErrorLocal]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(ensureOutput IsNot Nothing AndAlso ensureOutput.ContainsKey("ensureErrorMessage") AndAlso ensureOutput("ensureErrorMessage") IsNot Nothing, ensureOutput("ensureErrorMessage").ToString(), "Unknown folder setup error.")]</InArgument></Assign.Value></Assign>

        <If Condition="[ensureStatusLocal = &quot;SUCCESS&quot;]">
          <If.Then>
            <iaw:InvokeWorkflow ResponseCode="{x:Null}" Arguments="[New Dictionary(Of String, Object) From {{&quot;inputFolderPath&quot;,inputFolderPath},{&quot;maxDocuments&quot;,maxDocuments},{&quot;logFile&quot;,logFile}}]" ContinueOnError="False" DisplayName="Build Document Worklist" OutputArguments="[worklistOutput]" WorkflowFile="[projectPath+&quot;\BuildDocumentWorklist.xaml&quot;]" />
          </If.Then>
          <If.Else>
            <Sequence>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[worklistStatusLocal]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["FAILED"]</InArgument></Assign.Value></Assign>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[worklistErrorLocal]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[ensureErrorLocal]</InArgument></Assign.Value></Assign>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[worklistModeLocal]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["FOLDER_SETUP_FAILED"]</InArgument></Assign.Value></Assign>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:Int32">[worklistCountLocal]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:Int32">[0]</InArgument></Assign.Value></Assign>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[worklistJsonLocal]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["[]"]</InArgument></Assign.Value></Assign>
            </Sequence>
          </If.Else>
        </If>

        <If Condition="[String.IsNullOrWhiteSpace(worklistStatusLocal)]">
          <If.Then>
            <Sequence>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[worklistStatusLocal]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(worklistOutput IsNot Nothing AndAlso worklistOutput.ContainsKey("worklistStatus") AndAlso worklistOutput("worklistStatus") IsNot Nothing, worklistOutput("worklistStatus").ToString(), "FAILED")]</InArgument></Assign.Value></Assign>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[worklistErrorLocal]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(worklistOutput IsNot Nothing AndAlso worklistOutput.ContainsKey("worklistErrorMessage") AndAlso worklistOutput("worklistErrorMessage") IsNot Nothing, worklistOutput("worklistErrorMessage").ToString(), "Unknown worklist error.")]</InArgument></Assign.Value></Assign>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[worklistModeLocal]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(worklistOutput IsNot Nothing AndAlso worklistOutput.ContainsKey("worklistMode") AndAlso worklistOutput("worklistMode") IsNot Nothing, worklistOutput("worklistMode").ToString(), "UNSET")]</InArgument></Assign.Value></Assign>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:Int32">[worklistCountLocal]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:Int32">[If(worklistOutput IsNot Nothing AndAlso worklistOutput.ContainsKey("worklistCount") AndAlso worklistOutput("worklistCount") IsNot Nothing, CInt(worklistOutput("worklistCount").ToString()), 0)]</InArgument></Assign.Value></Assign>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:Int32">[worklistCount]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:Int32">[worklistCountLocal]</InArgument></Assign.Value></Assign>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[worklistJsonLocal]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(worklistOutput IsNot Nothing AndAlso worklistOutput.ContainsKey("worklistJson") AndAlso worklistOutput("worklistJson") IsNot Nothing, worklistOutput("worklistJson").ToString(), "[]")]</InArgument></Assign.Value></Assign>
            </Sequence>
          </If.Then>
        </If>

        <If Condition="[worklistStatusLocal = &quot;SUCCESS&quot; AndAlso worklistCountLocal &gt; 0]">
          <If.Then>
            <Sequence>
              <Assign><Assign.To><OutArgument x:TypeArguments="njl:JArray">[documents]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="njl:JArray">[JArray.Parse(worklistJsonLocal)]</InArgument></Assign.Value></Assign>
              <ForEach x:TypeArguments="njl:JToken" Values="[documents]">
                <ActivityAction x:TypeArguments="njl:JToken">
                  <ActivityAction.Argument>
                    <DelegateInArgument x:TypeArguments="njl:JToken" Name="documentItem" />
                  </ActivityAction.Argument>
                  <Sequence>
                    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[childDocumentPath]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(documentItem("documentPath") IsNot Nothing, documentItem("documentPath").ToString(), "")]</InArgument></Assign.Value></Assign>
                    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[childJsonPath]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(documentItem("jsonPath") IsNot Nothing, documentItem("jsonPath").ToString(), "")]</InArgument></Assign.Value></Assign>
                    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[childSourceName]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(documentItem("sourceDocumentName") IsNot Nothing, documentItem("sourceDocumentName").ToString(), If(Not String.IsNullOrWhiteSpace(childDocumentPath), System.IO.Path.GetFileName(childDocumentPath), "unknown-source"))]</InArgument></Assign.Value></Assign>
                    <ias:Append_Line ContinueOnError="True" ErrorCode="{x:Null}" DisplayName="Log Batch Document Start" Line="[System.Environment.NewLine+&quot;  BatchDocument:&quot;+System.Environment.NewLine+&quot;    Source: &quot;+childSourceName+System.Environment.NewLine+&quot;    Path: &quot;+childDocumentPath]" Source="[logFile]" />

                    <iaw:InvokeWorkflow ResponseCode="{x:Null}" Arguments="[New Dictionary(Of String, Object) From {{&quot;inputFolderPath&quot;,inputFolderPath},{&quot;sourceDocumentPath&quot;,childDocumentPath},{&quot;sourceJsonPath&quot;,childJsonPath},{&quot;sourceDocumentName&quot;,childSourceName},{&quot;logFile&quot;,logFile}}]" ContinueOnError="False" DisplayName="Claim Batch Document" OutputArguments="[claimOutput]" WorkflowFile="[projectPath+&quot;\ClaimBatchDocument.xaml&quot;]" />
                    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[claimStatusLocal]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(claimOutput IsNot Nothing AndAlso claimOutput.ContainsKey("claimStatus") AndAlso claimOutput("claimStatus") IsNot Nothing, claimOutput("claimStatus").ToString(), "FAILED")]</InArgument></Assign.Value></Assign>
