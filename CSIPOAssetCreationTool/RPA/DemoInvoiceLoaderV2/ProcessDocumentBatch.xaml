                      <If.Else>
                        <Sequence>
                          <Assign><Assign.To><OutArgument x:TypeArguments="x:Int32">[failureCount]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:Int32">[failureCount + 1]</InArgument></Assign.Value></Assign>
                          <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[failedDocumentsCsvLocal]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[failedDocumentsCsvLocal + If(String.IsNullOrWhiteSpace(failedDocumentsCsvLocal), "", ",") + childSourceName]</InArgument></Assign.Value></Assign>
