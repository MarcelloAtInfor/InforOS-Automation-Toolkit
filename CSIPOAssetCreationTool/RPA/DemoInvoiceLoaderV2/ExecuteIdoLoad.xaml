    <x:Property Name="operationStatus" Type="OutArgument(x:String)" />
    <x:Property Name="errorMessage" Type="OutArgument(x:String)" />
  </x:Members>
  <mva:VisualBasic.Settings>
    <x:Null />
  </mva:VisualBasic.Settings>
  <sap2010:WorkflowViewState.IdRef>RehostedWorkflowDesigner.Workflow_1</sap2010:WorkflowViewState.IdRef>
  <TextExpression.NamespacesForImplementation>
    <sco:Collection x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.Activities</x:String>
      <x:String>System.Activities.Statements</x:String>
      <x:String>System.Activities.Expressions</x:String>
      <x:String>System.Activities.Validation</x:String>
      <x:String>System.Activities.XamlIntegration</x:String>
      <x:String>Microsoft.VisualBasic.Activities</x:String>
      <x:String>System.Activities.Debugger.Symbol</x:String>
      <x:String>System.Collections.Generic</x:String>
      <x:String>System.Windows.Markup</x:String>
      <x:String>Infor.RPA.Utilities</x:String>
      <x:String>Newtonsoft.Json.Linq</x:String>
    </sco:Collection>
  </TextExpression.NamespacesForImplementation>
  <TextExpression.ReferencesForImplementation>
    <sco:Collection x:TypeArguments="AssemblyReference">
      <AssemblyReference>System.Activities</AssemblyReference>
      <AssemblyReference>mscorlib</AssemblyReference>
      <AssemblyReference>System.Core</AssemblyReference>
      <AssemblyReference>PresentationFramework</AssemblyReference>
      <AssemblyReference>WindowsBase</AssemblyReference>
      <AssemblyReference>PresentationCore</AssemblyReference>
      <AssemblyReference>System.Xaml</AssemblyReference>
      <AssemblyReference>System</AssemblyReference>
      <AssemblyReference>System.ComponentModel.Composition</AssemblyReference>
      <AssemblyReference>Infor.RPA.Utilities</AssemblyReference>
      <AssemblyReference>Newtonsoft.Json</AssemblyReference>
    </sco:Collection>
  </TextExpression.ReferencesForImplementation>
  <Sequence DisplayName="Execute IDO Load" sap2010:WorkflowViewState.IdRef="Sequence_1">
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="requestUrl" />
      <Variable x:TypeArguments="iru:ResponseObject" Name="apiResponse" />
      <Variable x:TypeArguments="x:Int32" Name="apiResponseCode" />
      <Variable x:TypeArguments="njl:JObject" Name="parsed" />
      <Variable x:TypeArguments="x:Boolean" Name="bodySuccessFlag" Default="True" />
      <Variable x:TypeArguments="x:String" Name="bodyMessage" />
    </Sequence.Variables>
    <Assign DisplayName="Init Operation Status" sap2010:WorkflowViewState.IdRef="Assign_1">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">[operationStatus]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">["PENDING"]</InArgument>
      </Assign.Value>
    </Assign>
    <Assign DisplayName="Init Error Message" sap2010:WorkflowViewState.IdRef="Assign_2">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">[errorMessage]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">[""]</InArgument>
      </Assign.Value>
    </Assign>
    <Assign DisplayName="Init Body Message" sap2010:WorkflowViewState.IdRef="Assign_3">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">[bodyMessage]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">[""]</InArgument>
      </Assign.Value>
    </Assign>
    <Assign DisplayName="Build Request Url" sap2010:WorkflowViewState.IdRef="Assign_4">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">[requestUrl]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">[tenantURL.TrimEnd("/"c)+"/CSI/IDORequestService/ido/load/"+idoName+"?properties="+System.Uri.EscapeDataString(properties)+"&amp;recordCap="+If(String.IsNullOrWhiteSpace(recordCap), "100", recordCap)+If(String.IsNullOrWhiteSpace(filter), "", "&amp;filter="+System.Uri.EscapeDataString(filter))+If(String.IsNullOrWhiteSpace(orderBy), "", "&amp;orderby="+System.Uri.EscapeDataString(orderBy))]</InArgument>
      </Assign.Value>
    </Assign>
    <ias:Append_Line ErrorCode="{x:Null}" ContinueOnError="True" DisplayName="Log IDO Load Start" sap2010:WorkflowViewState.IdRef="Append_Line_1" Line="[System.Environment.NewLine+&quot;  ExecuteIdoLoad: &quot;+idoName+&quot; - URL: &quot;+requestUrl]" Source="[logFile]" />
    <iai:IONAPIRequestWizard FileAttachments="{x:Null}" PostData="{x:Null}" StatusCode="{x:Null}" ContentType="application_json" ContinueOnError="True" DisplayName="GET IDO Load" HttpMethod="GET" sap2010:WorkflowViewState.IdRef="IONAPIRequestWizard_1" Response="[apiResponse]" ResponseCode="[apiResponseCode]" Url="[requestUrl]">
      <iai:IONAPIRequestWizard.Headers>
        <scg:List x:TypeArguments="scg:List(x:String)" Capacity="4">
          <scg:List x:TypeArguments="x:String" Capacity="1">
            <x:String>X-Infor-MongooseConfig</x:String>
          </scg:List>
          <scg:List x:TypeArguments="x:String" Capacity="1">
            <x:String>YOUR_SITE</x:String>
          </scg:List>
        </scg:List>
      </iai:IONAPIRequestWizard.Headers>
    </iai:IONAPIRequestWizard>
    <Assign DisplayName="Set Response Json" sap2010:WorkflowViewState.IdRef="Assign_5">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">[responseJson]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">[If(apiResponse Is Nothing, "", apiResponse.readastext)]</InArgument>
      </Assign.Value>
    </Assign>
    <If Condition="[Not String.IsNullOrWhiteSpace(responseJson) AndAlso responseJson.TrimStart().StartsWith(&quot;{&quot;)]" DisplayName="Parse JSON Body" sap2010:WorkflowViewState.IdRef="If_1">
      <If.Then>
        <Sequence DisplayName="Read Body Flags" sap2010:WorkflowViewState.IdRef="Sequence_2">
          <Assign DisplayName="Parse Body JSON" sap2010:WorkflowViewState.IdRef="Assign_6">
            <Assign.To>
              <OutArgument x:TypeArguments="njl:JObject">[parsed]</OutArgument>
            </Assign.To>
            <Assign.Value>
              <InArgument x:TypeArguments="njl:JObject">[JObject.Parse(responseJson)]</InArgument>
            </Assign.Value>
          </Assign>
          <Assign DisplayName="Read Body Success" sap2010:WorkflowViewState.IdRef="Assign_7">
            <Assign.To>
              <OutArgument x:TypeArguments="x:Boolean">[bodySuccessFlag]</OutArgument>
            </Assign.To>
            <Assign.Value>
              <InArgument x:TypeArguments="x:Boolean">[If(parsed("Success") IsNot Nothing, CBool(parsed("Success").ToString()), True)]</InArgument>
            </Assign.Value>
          </Assign>
          <Assign DisplayName="Read Body Message" sap2010:WorkflowViewState.IdRef="Assign_8">
            <Assign.To>
              <OutArgument x:TypeArguments="x:String">[bodyMessage]</OutArgument>
            </Assign.To>
            <Assign.Value>
              <InArgument x:TypeArguments="x:String">[If(parsed("Message") IsNot Nothing, parsed("Message").ToString(), "")]</InArgument>
            </Assign.Value>
          </Assign>
        </Sequence>
      </If.Then>
    </If>
    <If Condition="[apiResponseCode &gt;= 200 AndAlso apiResponseCode &lt; 300 AndAlso (apiResponse Is Nothing OrElse Not apiResponse.readastext.StartsWith(&quot;Code:&quot;)) AndAlso bodySuccessFlag]" DisplayName="Check Load Success" sap2010:WorkflowViewState.IdRef="If_2">
      <If.Then>
        <Assign DisplayName="Set Success Status" sap2010:WorkflowViewState.IdRef="Assign_9">
          <Assign.To>
            <OutArgument x:TypeArguments="x:String">[operationStatus]</OutArgument>
          </Assign.To>
          <Assign.Value>
            <InArgument x:TypeArguments="x:String">["SUCCESS"]</InArgument>
          </Assign.Value>
        </Assign>
      </If.Then>
      <If.Else>
        <Sequence DisplayName="Handle Load Failure" sap2010:WorkflowViewState.IdRef="Sequence_3">
          <Assign DisplayName="Set Failed Status" sap2010:WorkflowViewState.IdRef="Assign_10">
            <Assign.To>
              <OutArgument x:TypeArguments="x:String">[operationStatus]</OutArgument>
            </Assign.To>
            <Assign.Value>
              <InArgument x:TypeArguments="x:String">["FAILED"]</InArgument>
            </Assign.Value>
          </Assign>
          <Assign DisplayName="Set Load Error Message" sap2010:WorkflowViewState.IdRef="Assign_11">
            <Assign.To>
              <OutArgument x:TypeArguments="x:String">[errorMessage]</OutArgument>
            </Assign.To>
            <Assign.Value>
              <InArgument x:TypeArguments="x:String">[If(apiResponseCode &gt;= 200 AndAlso apiResponseCode &lt; 300 AndAlso Not String.IsNullOrWhiteSpace(bodyMessage), "IDO load failed: "+bodyMessage, "IDO load failed with code "+apiResponseCode.ToString()+": "+If(apiResponse Is Nothing, "No response", apiResponse.readastext))]</InArgument>
            </Assign.Value>
          </Assign>
        </Sequence>
      </If.Else>
    </If>
  </Sequence>
