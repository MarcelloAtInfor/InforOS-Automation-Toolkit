<Activity mc:Ignorable="sap sap2010 sads" x:Class="RehostedWorkflowDesigner.Workflow"
 xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
 xmlns:ias="clr-namespace:Infor.Activities.Sys;assembly=Infor.Activities.Sys"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 xmlns:mva="clr-namespace:Microsoft.VisualBasic.Activities;assembly=System.Activities"
 xmlns:s="clr-namespace:System;assembly=mscorlib"
 xmlns:sads="http://schemas.microsoft.com/netfx/2010/xaml/activities/debugger"
 xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
 xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
 xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=mscorlib"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <x:Members>
    <x:Property Name="inputFolderPath" Type="InArgument(x:String)" />
    <x:Property Name="maxDocuments" Type="InArgument(x:Int32)" />
    <x:Property Name="logFile" Type="InArgument(x:String)" />
    <x:Property Name="worklistStatus" Type="OutArgument(x:String)" />
    <x:Property Name="worklistErrorMessage" Type="OutArgument(x:String)" />
    <x:Property Name="worklistJson" Type="OutArgument(x:String)" />
    <x:Property Name="worklistCount" Type="OutArgument(x:Int32)" />
    <x:Property Name="worklistMode" Type="OutArgument(x:String)" />
    <x:Property Name="firstDocumentPath" Type="OutArgument(x:String)" />
    <x:Property Name="firstJsonPath" Type="OutArgument(x:String)" />
    <x:Property Name="firstSourceDocumentName" Type="OutArgument(x:String)" />
  </x:Members>
  <mva:VisualBasic.Settings>
    <x:Null />
  </mva:VisualBasic.Settings>
  <sap2010:WorkflowViewState.IdRef>RehostedWorkflowDesigner.Workflow_1</sap2010:WorkflowViewState.IdRef>
  <TextExpression.NamespacesForImplementation>
    <sco:Collection x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.Activities</x:String>
      <x:String>System.Activities.Statements</x:String>
      <x:String>Microsoft.VisualBasic.Activities</x:String>
      <x:String>System.Linq</x:String>
    </sco:Collection>
  </TextExpression.NamespacesForImplementation>
  <TryCatch DisplayName="Build Document Worklist">
    <TryCatch.Variables>
      <Variable x:TypeArguments="x:String" Name="worklistFragments" />
      <Variable x:TypeArguments="x:String" Name="candidateDocumentPath" />
      <Variable x:TypeArguments="x:String" Name="candidateJsonPath" />
      <Variable x:TypeArguments="x:String" Name="candidateSourceName" />
      <Variable x:TypeArguments="x:String" Name="effectiveMode" />
    </TryCatch.Variables>
    <TryCatch.Try>
      <Sequence>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[worklistStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["PENDING"]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[worklistErrorMessage]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[""]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[worklistJson]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["[]"]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:Int32">[worklistCount]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:Int32">[0]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[worklistMode]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["UNSET"]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[firstDocumentPath]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[""]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[firstJsonPath]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[""]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[firstSourceDocumentName]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[""]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[worklistFragments]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[""]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[effectiveMode]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["PDF_FIRST"]</InArgument></Assign.Value></Assign>
        <If Condition="[String.IsNullOrWhiteSpace(inputFolderPath) OrElse Not System.IO.Directory.Exists(inputFolderPath)]">
          <If.Then>
            <Sequence>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[worklistStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["FAILED"]</InArgument></Assign.Value></Assign>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[worklistErrorMessage]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["Input folder does not exist or was not supplied."]</InArgument></Assign.Value></Assign>
            </Sequence>
          </If.Then>
          <If.Else>
            <Sequence>
              <If Condition="[Not System.IO.Directory.GetFiles(inputFolderPath, &quot;*.pdf&quot;).Any()]">
                <If.Then>
                  <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[effectiveMode]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["JSON_SIDECAR_ONLY"]</InArgument></Assign.Value></Assign>
                </If.Then>
                <If.Else>
                  <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[effectiveMode]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["PDF_FIRST"]</InArgument></Assign.Value></Assign>
                </If.Else>
              </If>
              <If Condition="[effectiveMode = &quot;PDF_FIRST&quot;]">
                <If.Then>
                  <ForEach x:TypeArguments="x:String" Values="[System.IO.Directory.GetFiles(inputFolderPath, &quot;*.pdf&quot;).OrderBy(Function(p) p)]">
                    <ActivityAction x:TypeArguments="x:String">
                      <ActivityAction.Argument>
                        <DelegateInArgument x:TypeArguments="x:String" Name="candidatePath" />
                      </ActivityAction.Argument>
                      <Sequence>
                        <If Condition="[maxDocuments &lt;= 0 OrElse worklistCount &lt; maxDocuments]">
                          <If.Then>
                            <Sequence>
                              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[candidateDocumentPath]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[candidatePath]</InArgument></Assign.Value></Assign>
                              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[candidateJsonPath]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Path.ChangeExtension(candidatePath, ".json")]</InArgument></Assign.Value></Assign>
                              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[candidateSourceName]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Path.GetFileName(candidatePath)]</InArgument></Assign.Value></Assign>
                              <If Condition="[worklistCount = 0]">
                                <If.Then>
                                  <Sequence>
                                    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[firstDocumentPath]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[candidateDocumentPath]</InArgument></Assign.Value></Assign>
                                    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[firstJsonPath]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[candidateJsonPath]</InArgument></Assign.Value></Assign>
                                    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[firstSourceDocumentName]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[candidateSourceName]</InArgument></Assign.Value></Assign>
                                  </Sequence>
                                </If.Then>
                              </If>
                              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[worklistFragments]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[worklistFragments + If(String.IsNullOrWhiteSpace(worklistFragments), "", ",") + "{""documentPath"":""" + candidateDocumentPath.Replace("\","\\").Replace("""","") + """,""jsonPath"":""" + candidateJsonPath.Replace("\","\\").Replace("""","") + """,""sourceDocumentName"":""" + candidateSourceName.Replace("""","") + """,""mode"":""" + effectiveMode + """}"]</InArgument></Assign.Value></Assign>
                              <Assign><Assign.To><OutArgument x:TypeArguments="x:Int32">[worklistCount]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:Int32">[worklistCount + 1]</InArgument></Assign.Value></Assign>
                            </Sequence>
                          </If.Then>
                        </If>
                      </Sequence>
                    </ActivityAction>
                  </ForEach>
                </If.Then>
                <If.Else>
                  <ForEach x:TypeArguments="x:String" Values="[System.IO.Directory.GetFiles(inputFolderPath, &quot;*.json&quot;).Where(Function(p) Not System.IO.Path.GetFileName(p).Equals(&quot;project.json&quot;, StringComparison.OrdinalIgnoreCase) AndAlso Not System.IO.Path.GetFileName(p).Equals(&quot;DefaultDocumentTemplate.json&quot;, StringComparison.OrdinalIgnoreCase) AndAlso Not System.IO.Path.GetFileName(p).Equals(&quot;IDDPTemplate.json&quot;, StringComparison.OrdinalIgnoreCase)).OrderBy(Function(p) p)]">
                    <ActivityAction x:TypeArguments="x:String">
                      <ActivityAction.Argument>
                        <DelegateInArgument x:TypeArguments="x:String" Name="candidatePath" />
                      </ActivityAction.Argument>
                      <Sequence>
                        <If Condition="[maxDocuments &lt;= 0 OrElse worklistCount &lt; maxDocuments]">
                          <If.Then>
                            <Sequence>
                              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[candidateJsonPath]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[candidatePath]</InArgument></Assign.Value></Assign>
                              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[candidateDocumentPath]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Path.ChangeExtension(candidatePath, ".pdf")]</InArgument></Assign.Value></Assign>
                              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[candidateSourceName]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Path.GetFileName(System.IO.Path.ChangeExtension(candidatePath, ".pdf"))]</InArgument></Assign.Value></Assign>
                              <If Condition="[worklistCount = 0]">
                                <If.Then>
                                  <Sequence>
                                    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[firstDocumentPath]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[candidateDocumentPath]</InArgument></Assign.Value></Assign>
                                    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[firstJsonPath]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[candidateJsonPath]</InArgument></Assign.Value></Assign>
                                    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[firstSourceDocumentName]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[candidateSourceName]</InArgument></Assign.Value></Assign>
                                  </Sequence>
                                </If.Then>
                              </If>
                              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[worklistFragments]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[worklistFragments + If(String.IsNullOrWhiteSpace(worklistFragments), "", ",") + "{""documentPath"":""" + candidateDocumentPath.Replace("\","\\").Replace("""","") + """,""jsonPath"":""" + candidateJsonPath.Replace("\","\\").Replace("""","") + """,""sourceDocumentName"":""" + candidateSourceName.Replace("""","") + """,""mode"":""" + effectiveMode + """}"]</InArgument></Assign.Value></Assign>
                              <Assign><Assign.To><OutArgument x:TypeArguments="x:Int32">[worklistCount]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:Int32">[worklistCount + 1]</InArgument></Assign.Value></Assign>
                            </Sequence>
                          </If.Then>
                        </If>
                      </Sequence>
                    </ActivityAction>
                  </ForEach>
                </If.Else>
              </If>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[worklistMode]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[effectiveMode]</InArgument></Assign.Value></Assign>
              <If Condition="[worklistCount &gt; 0]">
                <If.Then>
                  <Sequence>
                    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[worklistJson]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["[" + worklistFragments + "]"]</InArgument></Assign.Value></Assign>
                    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[worklistStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["SUCCESS"]</InArgument></Assign.Value></Assign>
                  </Sequence>
                </If.Then>
                <If.Else>
                  <Sequence>
                    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[worklistStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["FAILED"]</InArgument></Assign.Value></Assign>
                    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[worklistErrorMessage]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["No eligible documents were found for the worklist."]</InArgument></Assign.Value></Assign>
                  </Sequence>
                </If.Else>
              </If>
            </Sequence>
          </If.Else>
        </If>
        <ias:Append_Line ContinueOnError="True" ErrorCode="{x:Null}" DisplayName="Log Worklist Result" Line="[System.Environment.NewLine+&quot;  BuildDocumentWorklist:&quot;+System.Environment.NewLine+&quot;    Folder: &quot;+If(String.IsNullOrWhiteSpace(inputFolderPath), &quot;&lt;blank&gt;&quot;, inputFolderPath)+System.Environment.NewLine+&quot;    Status: &quot;+worklistStatus+System.Environment.NewLine+&quot;    Mode: &quot;+worklistMode+System.Environment.NewLine+&quot;    Count: &quot;+worklistCount.ToString()+If(String.IsNullOrWhiteSpace(worklistErrorMessage), &quot;&quot;, System.Environment.NewLine+&quot;    Error: &quot;+worklistErrorMessage)]" Source="[logFile]" />
      </Sequence>
    </TryCatch.Try>
    <TryCatch.Catches>
      <Catch x:TypeArguments="s:Exception">
        <ActivityAction x:TypeArguments="s:Exception">
          <ActivityAction.Argument>
            <DelegateInArgument x:TypeArguments="s:Exception" Name="exception" />
          </ActivityAction.Argument>
          <Sequence>
            <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[worklistStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["FAILED"]</InArgument></Assign.Value></Assign>
            <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[worklistMode]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["EXCEPTION"]</InArgument></Assign.Value></Assign>
            <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[worklistErrorMessage]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["BuildDocumentWorklist exception: " + exception.Message]</InArgument></Assign.Value></Assign>
          </Sequence>
        </ActivityAction>
      </Catch>
    </TryCatch.Catches>
  </TryCatch>
</Activity>
