  <Sequence DisplayName="Verify Purchase Order Lines" sap2010:WorkflowViewState.IdRef="Sequence_1">
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="queryFilter" />
      <Variable x:TypeArguments="x:String" Name="queryResponseJson" />
      <Variable x:TypeArguments="x:String" Name="queryStatus" />
      <Variable x:TypeArguments="x:String" Name="queryError" />
      <Variable x:TypeArguments="scg:IDictionary(x:String, x:Object)" Name="loadOutputDict" />
      <Variable x:TypeArguments="njl:JObject" Name="parsed" />
      <Variable x:TypeArguments="njl:JArray" Name="items" />
    </Sequence.Variables>
    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[verificationStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["PENDING"]</InArgument></Assign.Value></Assign>
    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[verificationErrorMessage]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[""]</InArgument></Assign.Value></Assign>
    <Assign><Assign.To><OutArgument x:TypeArguments="x:Int32">[actualLineCount]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:Int32">[0]</InArgument></Assign.Value></Assign>
    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[queryFilter]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["PoNum = '"+If(purchaseOrderNumber Is Nothing, "", purchaseOrderNumber.Replace("'", "''").Trim().ToUpper())+"'"]</InArgument></Assign.Value></Assign>
    <iaw:InvokeWorkflow Arguments="[New Dictionary(Of String, Object) From {{&quot;tenantURL&quot;,tenantURL},{&quot;site&quot;,site},{&quot;idoName&quot;,&quot;SLPoItems&quot;},{&quot;properties&quot;,&quot;PoNum,PoLine,Item,QtyOrderedConv,UM,Whse,DueDate,ItemCostConv,_ItemId&quot;},{&quot;filter&quot;,queryFilter},{&quot;orderBy&quot;,&quot;PoLine ASC&quot;},{&quot;recordCap&quot;,(If(expectedLineCount &lt;= 0, 20, expectedLineCount)).ToString()},{&quot;logFile&quot;,logFile}}]" ContinueOnError="False" DisplayName="Execute Verify PO Lines Load" sap2010:WorkflowViewState.IdRef="InvokeWorkflow_1" OutputArguments="[loadOutputDict]" ResponseCode="{x:Null}" WorkflowFile="[projectPath+&quot;\ExecuteIdoLoad.xaml&quot;]" />
    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[queryResponseJson]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(loadOutputDict IsNot Nothing AndAlso loadOutputDict.ContainsKey("responseJson"), loadOutputDict("responseJson").ToString(), "")]</InArgument></Assign.Value></Assign>
    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[queryStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(loadOutputDict IsNot Nothing AndAlso loadOutputDict.ContainsKey("operationStatus"), loadOutputDict("operationStatus").ToString(), "FAILED")]</InArgument></Assign.Value></Assign>
    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[queryError]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(loadOutputDict IsNot Nothing AndAlso loadOutputDict.ContainsKey("errorMessage"), loadOutputDict("errorMessage").ToString(), "")]</InArgument></Assign.Value></Assign>
    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[verificationResponseJson]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[queryResponseJson]</InArgument></Assign.Value></Assign>
    <If Condition="[queryStatus = &quot;SUCCESS&quot; AndAlso Not String.IsNullOrWhiteSpace(queryResponseJson)]">
      <If.Then>
        <Sequence>
          <Assign><Assign.To><OutArgument x:TypeArguments="njl:JObject">[parsed]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="njl:JObject">[JObject.Parse(queryResponseJson)]</InArgument></Assign.Value></Assign>
          <Assign><Assign.To><OutArgument x:TypeArguments="njl:JArray">[items]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="njl:JArray">[If(parsed("Items") IsNot Nothing AndAlso TypeOf parsed("Items") Is JArray, CType(parsed("Items"), JArray), New JArray())]</InArgument></Assign.Value></Assign>
          <Assign><Assign.To><OutArgument x:TypeArguments="x:Int32">[actualLineCount]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:Int32">[items.Count]</InArgument></Assign.Value></Assign>
        </Sequence>
      </If.Then>
    </If>
    <ias:Append_Line ErrorCode="{x:Null}" ContinueOnError="True" DisplayName="Log PO Line Verify Summary" sap2010:WorkflowViewState.IdRef="Append_Line_1" Line="[System.Environment.NewLine+&quot;  VerifyPurchaseOrderLines:&quot;+System.Environment.NewLine+&quot;    PoNum: &quot;+purchaseOrderNumber+System.Environment.NewLine+&quot;    ExpectedLines: &quot;+expectedLineCount.ToString()+System.Environment.NewLine+&quot;    ActualLines: &quot;+actualLineCount.ToString()+System.Environment.NewLine+&quot;    Status: &quot;+queryStatus+If(queryError.Length &gt; 0, System.Environment.NewLine+&quot;    Error: &quot;+queryError, &quot;&quot;)]" Source="[logFile]" />
    <If Condition="[queryStatus = &quot;SUCCESS&quot; AndAlso actualLineCount = expectedLineCount AndAlso actualLineCount &gt; 0]">
      <If.Then>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[verificationStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["SUCCESS"]</InArgument></Assign.Value></Assign>
      </If.Then>
      <If.Else>
        <Sequence>
          <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[verificationStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["FAILED"]</InArgument></Assign.Value></Assign>
          <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[verificationErrorMessage]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(queryStatus = "SUCCESS", "PO line verification count mismatch.", queryError)]</InArgument></Assign.Value></Assign>
        </Sequence>
      </If.Else>
    </If>
  </Sequence>
