<Activity mc:Ignorable="sap sap2010 sads" x:Class="RehostedWorkflowDesigner.Workflow"
 xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
 xmlns:iai="clr-namespace:Infor.Activities.IONAPI;assembly=Infor.Activities.IONAPI"
 xmlns:ias="clr-namespace:Infor.Activities.Sys;assembly=Infor.Activities.Sys"
 xmlns:iru="clr-namespace:Infor.RPA.Utilities;assembly=Infor.RPA.Utilities"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 xmlns:mva="clr-namespace:Microsoft.VisualBasic.Activities;assembly=System.Activities"
 xmlns:s="clr-namespace:System;assembly=mscorlib"
 xmlns:sads="http://schemas.microsoft.com/netfx/2010/xaml/activities/debugger"
 xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
 xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
 xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=mscorlib"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <x:Members>
    <x:Property Name="tenantURL" Type="InArgument(x:String)" />
    <x:Property Name="logFile" Type="InArgument(x:String)" />
    <x:Property Name="newVendorCreated" Type="InArgument(x:Boolean)" />
    <x:Property Name="createdItemCount" Type="InArgument(x:Int32)" />
    <x:Property Name="vendorRetrainingStatus" Type="OutArgument(x:String)" />
    <x:Property Name="vendorRetrainingError" Type="OutArgument(x:String)" />
    <x:Property Name="itemRetrainingStatus" Type="OutArgument(x:String)" />
    <x:Property Name="itemRetrainingError" Type="OutArgument(x:String)" />
  </x:Members>
  <mva:VisualBasic.Settings>
    <x:Null />
  </mva:VisualBasic.Settings>
  <TextExpression.NamespacesForImplementation>
    <sco:Collection x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.Activities</x:String>
      <x:String>System.Activities.Statements</x:String>
      <x:String>Microsoft.VisualBasic.Activities</x:String>
      <x:String>Infor.RPA.Utilities</x:String>
    </sco:Collection>
  </TextExpression.NamespacesForImplementation>
  <TextExpression.ReferencesForImplementation>
    <sco:Collection x:TypeArguments="AssemblyReference">
      <AssemblyReference>System.Activities</AssemblyReference>
      <AssemblyReference>mscorlib</AssemblyReference>
      <AssemblyReference>System.Core</AssemblyReference>
      <AssemblyReference>PresentationFramework</AssemblyReference>
      <AssemblyReference>WindowsBase</AssemblyReference>
      <AssemblyReference>PresentationCore</AssemblyReference>
      <AssemblyReference>System.Xaml</AssemblyReference>
      <AssemblyReference>System</AssemblyReference>
      <AssemblyReference>Microsoft.Bcl.AsyncInterfaces</AssemblyReference>
      <AssemblyReference>System.ComponentModel.Composition</AssemblyReference>
      <AssemblyReference>System.Memory</AssemblyReference>
      <AssemblyReference>System.ValueTuple</AssemblyReference>
      <AssemblyReference>System.Runtime.WindowsRuntime</AssemblyReference>
      <AssemblyReference>Infor.RPA.Utilities</AssemblyReference>
    </sco:Collection>
  </TextExpression.ReferencesForImplementation>
  <TryCatch DisplayName="Start Retraining Workflows">
    <TryCatch.Variables>
      <Variable x:TypeArguments="x:String" Name="workflowEndpoint" />
      <Variable x:TypeArguments="x:String" Name="vendorInstanceName" />
      <Variable x:TypeArguments="x:String" Name="vendorPayload" />
      <Variable x:TypeArguments="iru:ResponseObject" Name="vendorResponse" />
      <Variable x:TypeArguments="x:Int32" Name="vendorResponseCode" />
      <Variable x:TypeArguments="x:String" Name="itemInstanceName" />
      <Variable x:TypeArguments="x:String" Name="itemPayload" />
      <Variable x:TypeArguments="iru:ResponseObject" Name="itemResponse" />
      <Variable x:TypeArguments="x:Int32" Name="itemResponseCode" />
    </TryCatch.Variables>
    <TryCatch.Try>
      <Sequence>
        <Assign>
          <Assign.To>
            <OutArgument x:TypeArguments="x:String">[vendorRetrainingStatus]</OutArgument>
          </Assign.To>
          <Assign.Value>
            <InArgument x:TypeArguments="x:String">["Not needed"]</InArgument>
          </Assign.Value>
        </Assign>
        <Assign>
          <Assign.To>
            <OutArgument x:TypeArguments="x:String">[vendorRetrainingError]</OutArgument>
          </Assign.To>
          <Assign.Value>
            <InArgument x:TypeArguments="x:String">[""]</InArgument>
          </Assign.Value>
        </Assign>
        <Assign>
          <Assign.To>
            <OutArgument x:TypeArguments="x:String">[itemRetrainingStatus]</OutArgument>
          </Assign.To>
          <Assign.Value>
            <InArgument x:TypeArguments="x:String">["Not needed"]</InArgument>
          </Assign.Value>
        </Assign>
        <Assign>
          <Assign.To>
            <OutArgument x:TypeArguments="x:String">[itemRetrainingError]</OutArgument>
          </Assign.To>
          <Assign.Value>
            <InArgument x:TypeArguments="x:String">[""]</InArgument>
          </Assign.Value>
        </Assign>
        <Assign>
          <Assign.To>
            <OutArgument x:TypeArguments="x:String">[workflowEndpoint]</OutArgument>
          </Assign.To>
          <Assign.Value>
            <InArgument x:TypeArguments="x:String">[tenantURL.TrimEnd("/"c)+"/IONSERVICES/process/application/v1/workflow/start?logicalId=lid://infor.genai.tool"]</InArgument>
          </Assign.Value>
        </Assign>
        <If Condition="[newVendorCreated]">
          <If.Then>
            <Sequence>
              <Assign>
                <Assign.To>
                  <OutArgument x:TypeArguments="x:String">[vendorInstanceName]</OutArgument>
                </Assign.To>
                <Assign.Value>
                  <InArgument x:TypeArguments="x:String">["VendorRetrain_"+System.DateTime.Now.ToString("yyyyMMdd_HHmmss")]</InArgument>
                </Assign.Value>
              </Assign>
              <Assign>
                <Assign.To>
                  <OutArgument x:TypeArguments="x:String">[vendorPayload]</OutArgument>
                </Assign.To>
                <Assign.Value>
                  <InArgument x:TypeArguments="x:String">["{""workflowName"":""CSI_VendorName_similarity"",""instanceName"":""" + vendorInstanceName + """}"]</InArgument>
                </Assign.Value>
              </Assign>
              <iai:IONAPIRequestWizard FileAttachments="{x:Null}" QueryParameters="{x:Null}" StatusCode="{x:Null}" ContentType="application_json" ContinueOnError="True" DisplayName="Start Vendor Retraining Workflow" HttpMethod="POST" PostData="[vendorPayload]" Response="[vendorResponse]" ResponseCode="[vendorResponseCode]" Url="[workflowEndpoint]">
                <iai:IONAPIRequestWizard.Headers>
                  <scg:List x:TypeArguments="scg:List(x:String)" Capacity="4"
                    xmlns:scg="clr-namespace:System.Collections.Generic;assembly=mscorlib">
                    <scg:List x:TypeArguments="x:String" Capacity="0" />
                    <scg:List x:TypeArguments="x:String" Capacity="0" />
                  </scg:List>
                </iai:IONAPIRequestWizard.Headers>
              </iai:IONAPIRequestWizard>
              <If Condition="[vendorResponseCode &gt;= 200 AndAlso vendorResponseCode &lt; 300 AndAlso (vendorResponse Is Nothing OrElse Not vendorResponse.readastext.StartsWith(&quot;Code:&quot;))]">
                <If.Then>
                  <Assign>
                    <Assign.To>
                      <OutArgument x:TypeArguments="x:String">[vendorRetrainingStatus]</OutArgument>
                    </Assign.To>
                    <Assign.Value>
                      <InArgument x:TypeArguments="x:String">["Triggered"]</InArgument>
                    </Assign.Value>
                  </Assign>
                </If.Then>
                <If.Else>
                  <Sequence>
                    <Assign>
                      <Assign.To>
                        <OutArgument x:TypeArguments="x:String">[vendorRetrainingStatus]</OutArgument>
                      </Assign.To>
                      <Assign.Value>
                        <InArgument x:TypeArguments="x:String">["Failed"]</InArgument>
                      </Assign.Value>
                    </Assign>
                    <Assign>
                      <Assign.To>
                        <OutArgument x:TypeArguments="x:String">[vendorRetrainingError]</OutArgument>
                      </Assign.To>
                      <Assign.Value>
                        <InArgument x:TypeArguments="x:String">["Vendor retraining workflow start failed with code "+vendorResponseCode.ToString()+": "+If(vendorResponse IsNot Nothing, vendorResponse.readastext, "No response")]</InArgument>
                      </Assign.Value>
                    </Assign>
                  </Sequence>
                </If.Else>
              </If>
              <ias:Append_Line ErrorCode="{x:Null}" ContinueOnError="True" DisplayName="Log Vendor Retraining Result" Line="[System.Environment.NewLine+&quot;  Retraining:&quot;+System.Environment.NewLine+&quot;    VendorSimilarity: &quot;+vendorRetrainingStatus+If(String.IsNullOrWhiteSpace(vendorRetrainingError), &quot;&quot;, System.Environment.NewLine+&quot;    VendorRetrainingError: &quot;+vendorRetrainingError)]" Source="[logFile]" />
            </Sequence>
          </If.Then>
        </If>
        <If Condition="[createdItemCount &gt; 0]">
          <If.Then>
            <Sequence>
              <Assign>
                <Assign.To>
                  <OutArgument x:TypeArguments="x:String">[itemInstanceName]</OutArgument>
                </Assign.To>
                <Assign.Value>
                  <InArgument x:TypeArguments="x:String">["ItemRetrain_"+System.DateTime.Now.ToString("yyyyMMdd_HHmmss")]</InArgument>
                </Assign.Value>
              </Assign>
              <Assign>
                <Assign.To>
                  <OutArgument x:TypeArguments="x:String">[itemPayload]</OutArgument>
                </Assign.To>
                <Assign.Value>
                  <InArgument x:TypeArguments="x:String">["{""workflowName"":""CSI_Item_similarity"",""instanceName"":""" + itemInstanceName + """}"]</InArgument>
                </Assign.Value>
              </Assign>
              <iai:IONAPIRequestWizard FileAttachments="{x:Null}" QueryParameters="{x:Null}" StatusCode="{x:Null}" ContentType="application_json" ContinueOnError="True" DisplayName="Start Item Retraining Workflow" HttpMethod="POST" PostData="[itemPayload]" Response="[itemResponse]" ResponseCode="[itemResponseCode]" Url="[workflowEndpoint]">
                <iai:IONAPIRequestWizard.Headers>
                  <scg:List x:TypeArguments="scg:List(x:String)" Capacity="4"
                    xmlns:scg="clr-namespace:System.Collections.Generic;assembly=mscorlib">
                    <scg:List x:TypeArguments="x:String" Capacity="0" />
                    <scg:List x:TypeArguments="x:String" Capacity="0" />
                  </scg:List>
                </iai:IONAPIRequestWizard.Headers>
              </iai:IONAPIRequestWizard>
              <If Condition="[itemResponseCode &gt;= 200 AndAlso itemResponseCode &lt; 300 AndAlso (itemResponse Is Nothing OrElse Not itemResponse.readastext.StartsWith(&quot;Code:&quot;))]">
                <If.Then>
                  <Assign>
                    <Assign.To>
                      <OutArgument x:TypeArguments="x:String">[itemRetrainingStatus]</OutArgument>
                    </Assign.To>
                    <Assign.Value>
                      <InArgument x:TypeArguments="x:String">["Triggered"]</InArgument>
                    </Assign.Value>
                  </Assign>
                </If.Then>
                <If.Else>
                  <Sequence>
                    <Assign>
                      <Assign.To>
                        <OutArgument x:TypeArguments="x:String">[itemRetrainingStatus]</OutArgument>
                      </Assign.To>
                      <Assign.Value>
                        <InArgument x:TypeArguments="x:String">["Failed"]</InArgument>
                      </Assign.Value>
                    </Assign>
                    <Assign>
                      <Assign.To>
                        <OutArgument x:TypeArguments="x:String">[itemRetrainingError]</OutArgument>
                      </Assign.To>
                      <Assign.Value>
                        <InArgument x:TypeArguments="x:String">["Item retraining workflow start failed with code "+itemResponseCode.ToString()+": "+If(itemResponse IsNot Nothing, itemResponse.readastext, "No response")]</InArgument>
                      </Assign.Value>
                    </Assign>
                  </Sequence>
                </If.Else>
              </If>
              <ias:Append_Line ErrorCode="{x:Null}" ContinueOnError="True" DisplayName="Log Item Retraining Result" Line="[System.Environment.NewLine+&quot;  Retraining:&quot;+System.Environment.NewLine+&quot;    ItemSimilarity: &quot;+itemRetrainingStatus+If(String.IsNullOrWhiteSpace(itemRetrainingError), &quot;&quot;, System.Environment.NewLine+&quot;    ItemRetrainingError: &quot;+itemRetrainingError)]" Source="[logFile]" />
            </Sequence>
          </If.Then>
        </If>
      </Sequence>
    </TryCatch.Try>
    <TryCatch.Catches>
      <Catch x:TypeArguments="s:Exception">
        <ActivityAction x:TypeArguments="s:Exception">
          <ActivityAction.Argument>
            <DelegateInArgument x:TypeArguments="s:Exception" Name="exception" />
          </ActivityAction.Argument>
          <Sequence>
            <ias:Append_Line ErrorCode="{x:Null}" ContinueOnError="True" DisplayName="Log Retraining Exception" Line="[System.Environment.NewLine+&quot;  RetrainingException: &quot;+exception.Message]" Source="[logFile]" />
            <If Condition="[newVendorCreated AndAlso vendorRetrainingStatus = &quot;Not needed&quot;]">
              <If.Then>
                <Sequence>
                  <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[vendorRetrainingStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["Failed"]</InArgument></Assign.Value></Assign>
                  <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[vendorRetrainingError]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["Exception: "+exception.Message]</InArgument></Assign.Value></Assign>
                </Sequence>
              </If.Then>
            </If>
            <If Condition="[createdItemCount &gt; 0 AndAlso itemRetrainingStatus = &quot;Not needed&quot;]">
              <If.Then>
                <Sequence>
                  <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[itemRetrainingStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["Failed"]</InArgument></Assign.Value></Assign>
                  <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[itemRetrainingError]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["Exception: "+exception.Message]</InArgument></Assign.Value></Assign>
                </Sequence>
              </If.Then>
            </If>
          </Sequence>
        </ActivityAction>
      </Catch>
    </TryCatch.Catches>
  </TryCatch>
</Activity>
