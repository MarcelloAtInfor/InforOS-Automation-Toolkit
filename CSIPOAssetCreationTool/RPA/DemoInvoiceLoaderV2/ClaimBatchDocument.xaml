<Activity mc:Ignorable="sap sap2010 sads" x:Class="RehostedWorkflowDesigner.Workflow"
 xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
 xmlns:ias="clr-namespace:Infor.Activities.Sys;assembly=Infor.Activities.Sys"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 xmlns:mva="clr-namespace:Microsoft.VisualBasic.Activities;assembly=System.Activities"
 xmlns:s="clr-namespace:System;assembly=mscorlib"
 xmlns:sads="http://schemas.microsoft.com/netfx/2010/xaml/activities/debugger"
 xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
 xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
 xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=mscorlib"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <x:Members>
    <x:Property Name="inputFolderPath" Type="InArgument(x:String)" />
    <x:Property Name="sourceDocumentPath" Type="InArgument(x:String)" />
    <x:Property Name="sourceJsonPath" Type="InArgument(x:String)" />
    <x:Property Name="sourceDocumentName" Type="InArgument(x:String)" />
    <x:Property Name="logFile" Type="InArgument(x:String)" />
    <x:Property Name="claimStatus" Type="OutArgument(x:String)" />
    <x:Property Name="claimErrorMessage" Type="OutArgument(x:String)" />
    <x:Property Name="claimedDocumentPath" Type="OutArgument(x:String)" />
    <x:Property Name="claimedJsonPath" Type="OutArgument(x:String)" />
  </x:Members>
  <mva:VisualBasic.Settings>
    <x:Null />
  </mva:VisualBasic.Settings>
  <TextExpression.NamespacesForImplementation>
    <sco:Collection x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.Activities</x:String>
      <x:String>System.Activities.Statements</x:String>
      <x:String>Microsoft.VisualBasic.Activities</x:String>
    </sco:Collection>
  </TextExpression.NamespacesForImplementation>
  <TryCatch DisplayName="Claim Batch Document">
    <TryCatch.Variables>
      <Variable x:TypeArguments="x:String" Name="runtimeRootFolder" />
      <Variable x:TypeArguments="x:String" Name="inProgressFolder" />
      <Variable x:TypeArguments="x:String" Name="documentTargetName" />
      <Variable x:TypeArguments="x:String" Name="jsonTargetName" />
      <Variable x:TypeArguments="x:Boolean" Name="sourceDocumentExists" />
      <Variable x:TypeArguments="x:Boolean" Name="sourceJsonExists" />
      <Variable x:TypeArguments="x:String" Name="moveOutput" />
    </TryCatch.Variables>
    <TryCatch.Try>
      <Sequence>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[claimStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["PENDING"]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[claimErrorMessage]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[""]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[runtimeRootFolder]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Directory.GetParent(inputFolderPath).FullName]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[inProgressFolder]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Path.Combine(runtimeRootFolder, "InProgress")]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[documentTargetName]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(String.IsNullOrWhiteSpace(sourceDocumentName), If(String.IsNullOrWhiteSpace(sourceDocumentPath), "unknown-document.pdf", System.IO.Path.GetFileName(sourceDocumentPath)), sourceDocumentName)]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[jsonTargetName]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(String.IsNullOrWhiteSpace(sourceJsonPath), System.IO.Path.ChangeExtension(documentTargetName, ".json"), System.IO.Path.GetFileName(sourceJsonPath))]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[claimedDocumentPath]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Path.Combine(inProgressFolder, documentTargetName)]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[claimedJsonPath]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Path.Combine(inProgressFolder, jsonTargetName)]</InArgument></Assign.Value></Assign>
        <ias:Path_Validate ErrorCode="{x:Null}" ContinueOnError="True" DisplayName="Check Source Document Exists" IsValid="[sourceDocumentExists]" Path="[sourceDocumentPath]" />
        <ias:Path_Validate ErrorCode="{x:Null}" ContinueOnError="True" DisplayName="Check Source Json Exists" IsValid="[sourceJsonExists]" Path="[sourceJsonPath]" />
        <If Condition="[Not sourceDocumentExists AndAlso Not sourceJsonExists]">
          <If.Then>
            <Sequence>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[claimStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["FAILED"]</InArgument></Assign.Value></Assign>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[claimErrorMessage]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["Neither the source document nor the source sidecar JSON exists for " + documentTargetName]</InArgument></Assign.Value></Assign>
            </Sequence>
          </If.Then>
          <If.Else>
            <Sequence>
              <If Condition="[sourceDocumentExists]">
                <If.Then>
                  <ias:File_Move ErrorCode="{x:Null}" ContinueOnError="False" DisplayName="Move Document To InProgress" OutputFile="[moveOutput]" OverwriteFile="True" Source="[sourceDocumentPath]" Target="[inProgressFolder]" targetName="[documentTargetName]" />
                </If.Then>
              </If>
              <If Condition="[sourceJsonExists]">
                <If.Then>
                  <ias:File_Move ErrorCode="{x:Null}" ContinueOnError="False" DisplayName="Move Json To InProgress" OutputFile="[moveOutput]" OverwriteFile="True" Source="[sourceJsonPath]" Target="[inProgressFolder]" targetName="[jsonTargetName]" />
                </If.Then>
              </If>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[claimStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["SUCCESS"]</InArgument></Assign.Value></Assign>
              <ias:Append_Line ContinueOnError="True" ErrorCode="{x:Null}" DisplayName="Log Claim Result" Line="[System.Environment.NewLine+&quot;  ClaimBatchDocument:&quot;+System.Environment.NewLine+&quot;    Source: &quot;+documentTargetName+System.Environment.NewLine+&quot;    ClaimedDocumentPath: &quot;+claimedDocumentPath+System.Environment.NewLine+&quot;    ClaimedJsonPath: &quot;+claimedJsonPath+System.Environment.NewLine+&quot;    DocumentMoved: &quot;+sourceDocumentExists.ToString()+System.Environment.NewLine+&quot;    JsonMoved: &quot;+sourceJsonExists.ToString()+System.Environment.NewLine+&quot;    Status: &quot;+claimStatus]" Source="[logFile]" />
            </Sequence>
          </If.Else>
        </If>
      </Sequence>
    </TryCatch.Try>
    <TryCatch.Catches>
      <Catch x:TypeArguments="s:Exception">
        <ActivityAction x:TypeArguments="s:Exception">
          <ActivityAction.Argument>
            <DelegateInArgument x:TypeArguments="s:Exception" Name="exception" />
          </ActivityAction.Argument>
          <Sequence>
            <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[claimStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["FAILED"]</InArgument></Assign.Value></Assign>
            <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[claimErrorMessage]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["ClaimBatchDocument exception: " + exception.Message]</InArgument></Assign.Value></Assign>
          </Sequence>
        </ActivityAction>
      </Catch>
    </TryCatch.Catches>
  </TryCatch>
</Activity>
