<Activity mc:Ignorable="sap sap2010 sads" x:Class="RehostedWorkflowDesigner.Workflow"
 xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
 xmlns:ias="clr-namespace:Infor.Activities.Sys;assembly=Infor.Activities.Sys"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 xmlns:mva="clr-namespace:Microsoft.VisualBasic.Activities;assembly=System.Activities"
 xmlns:s="clr-namespace:System;assembly=mscorlib"
 xmlns:sads="http://schemas.microsoft.com/netfx/2010/xaml/activities/debugger"
 xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
 xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
 xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=mscorlib"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <x:Members>
    <x:Property Name="inputFolderPath" Type="InArgument(x:String)" />
    <x:Property Name="logFile" Type="InArgument(x:String)" />
    <x:Property Name="ensureStatus" Type="OutArgument(x:String)" />
    <x:Property Name="ensureErrorMessage" Type="OutArgument(x:String)" />
    <x:Property Name="runtimeRootFolder" Type="OutArgument(x:String)" />
    <x:Property Name="inProgressFolder" Type="OutArgument(x:String)" />
    <x:Property Name="successFolder" Type="OutArgument(x:String)" />
    <x:Property Name="failureFolder" Type="OutArgument(x:String)" />
    <x:Property Name="successDateFolder" Type="OutArgument(x:String)" />
    <x:Property Name="failureDateFolder" Type="OutArgument(x:String)" />
  </x:Members>
  <mva:VisualBasic.Settings>
    <x:Null />
  </mva:VisualBasic.Settings>
  <TextExpression.NamespacesForImplementation>
    <sco:Collection x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.Activities</x:String>
      <x:String>System.Activities.Statements</x:String>
      <x:String>Microsoft.VisualBasic.Activities</x:String>
    </sco:Collection>
  </TextExpression.NamespacesForImplementation>
  <TryCatch DisplayName="Ensure Batch Folders">
    <TryCatch.Variables>
      <Variable x:TypeArguments="x:String" Name="todayFolder" />
    </TryCatch.Variables>
    <TryCatch.Try>
      <Sequence>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[ensureStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["PENDING"]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[ensureErrorMessage]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[""]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[todayFolder]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[System.DateTime.Now.ToString("yyyy-MM-dd")]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[runtimeRootFolder]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Directory.GetParent(inputFolderPath).FullName]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[inProgressFolder]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Path.Combine(runtimeRootFolder, "InProgress")]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[successFolder]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Path.Combine(runtimeRootFolder, "Success")]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[failureFolder]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Path.Combine(runtimeRootFolder, "Failure")]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[successDateFolder]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Path.Combine(successFolder, todayFolder)]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[failureDateFolder]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Path.Combine(failureFolder, todayFolder)]</InArgument></Assign.Value></Assign>
        <ias:Directory_Create ErrorCode="{x:Null}" OutputPath="{x:Null}" ContinueOnError="True" DisplayName="Ensure Input Folder" Name="[System.IO.Path.GetFileName(inputFolderPath)]" Target="[runtimeRootFolder]" />
        <ias:Directory_Create ErrorCode="{x:Null}" OutputPath="{x:Null}" ContinueOnError="True" DisplayName="Ensure InProgress Folder" Name="InProgress" Target="[runtimeRootFolder]" />
        <ias:Directory_Create ErrorCode="{x:Null}" OutputPath="{x:Null}" ContinueOnError="True" DisplayName="Ensure Success Folder" Name="Success" Target="[runtimeRootFolder]" />
        <ias:Directory_Create ErrorCode="{x:Null}" OutputPath="{x:Null}" ContinueOnError="True" DisplayName="Ensure Failure Folder" Name="Failure" Target="[runtimeRootFolder]" />
        <ias:Directory_Create ErrorCode="{x:Null}" OutputPath="{x:Null}" ContinueOnError="True" DisplayName="Ensure Success Date Folder" Name="[todayFolder]" Target="[successFolder]" />
        <ias:Directory_Create ErrorCode="{x:Null}" OutputPath="{x:Null}" ContinueOnError="True" DisplayName="Ensure Failure Date Folder" Name="[todayFolder]" Target="[failureFolder]" />
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[ensureStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["SUCCESS"]</InArgument></Assign.Value></Assign>
        <ias:Append_Line ContinueOnError="True" ErrorCode="{x:Null}" DisplayName="Log Folder Setup" Line="[System.Environment.NewLine+&quot;  EnsureBatchFolders:&quot;+System.Environment.NewLine+&quot;    Input: &quot;+inputFolderPath+System.Environment.NewLine+&quot;    InProgress: &quot;+inProgressFolder+System.Environment.NewLine+&quot;    SuccessDate: &quot;+successDateFolder+System.Environment.NewLine+&quot;    FailureDate: &quot;+failureDateFolder+System.Environment.NewLine+&quot;    Status: &quot;+ensureStatus]" Source="[logFile]" />
      </Sequence>
    </TryCatch.Try>
    <TryCatch.Catches>
      <Catch x:TypeArguments="s:Exception">
        <ActivityAction x:TypeArguments="s:Exception">
          <ActivityAction.Argument>
            <DelegateInArgument x:TypeArguments="s:Exception" Name="exception" />
          </ActivityAction.Argument>
          <Sequence>
            <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[ensureStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["FAILED"]</InArgument></Assign.Value></Assign>
            <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[ensureErrorMessage]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["EnsureBatchFolders exception: " + exception.Message]</InArgument></Assign.Value></Assign>
          </Sequence>
        </ActivityAction>
      </Catch>
    </TryCatch.Catches>
  </TryCatch>
</Activity>
