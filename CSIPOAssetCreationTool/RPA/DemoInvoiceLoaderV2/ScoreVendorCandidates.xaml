      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">[If(candidateName Is Nothing, "", System.Text.RegularExpressions.Regex.Replace(candidateName.Trim().ToUpper(), "\s+", " "))]</InArgument>
      </Assign.Value>
    </Assign>
    <Assign DisplayName="Normalize Candidate Address Line 1" sap2010:WorkflowViewState.IdRef="Assign_2">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">[normalizedCandidateAddressLine1]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">[System.Text.RegularExpressions.Regex.Replace((" " + System.Text.RegularExpressions.Regex.Replace(If(candidateAddressLine1 Is Nothing, "", candidateAddressLine1.Trim().ToUpper()), "[^A-Z0-9\s]", " ") + " ").Replace(" NORTH ", " N ").Replace(" SOUTH ", " S ").Replace(" EAST ", " E ").Replace(" WEST ", " W ").Replace(" STREET ", " ST ").Replace(" ROAD ", " RD ").Replace(" AVENUE ", " AVE ").Replace(" DRIVE ", " DR ").Replace(" LANE ", " LN ").Replace(" BOULEVARD ", " BLVD ").Replace(" COURT ", " CT "), "\s+", " ").Trim()]</InArgument>
      </Assign.Value>
    </Assign>
    <Assign DisplayName="Normalize Candidate City" sap2010:WorkflowViewState.IdRef="Assign_2A">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">[normalizedCandidateCity]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">[System.Text.RegularExpressions.Regex.Replace(If(candidateCity Is Nothing, "", candidateCity.Trim().ToUpper()), "\s+", " ").Trim()]</InArgument>
      </Assign.Value>
    </Assign>
    <Assign DisplayName="Normalize Candidate State" sap2010:WorkflowViewState.IdRef="Assign_2B">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">[normalizedCandidateState]</OutArgument>
      </Assign.To>
      <Assign.Value>
