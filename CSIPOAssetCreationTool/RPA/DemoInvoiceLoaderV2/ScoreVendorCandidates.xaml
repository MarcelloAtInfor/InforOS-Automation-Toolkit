        <InArgument x:TypeArguments="x:String">["{""vendNum"":""" + If(candidateVendNum Is Nothing, "", candidateVendNum.Replace("""","")) + """,""nameExact"":" + nameExact.ToString().ToLower() + ",""addressExact"":" + addressExact.ToString().ToLower() + ",""line1Exact"":" + line1Exact.ToString().ToLower() + ",""cityExact"":" + cityExact.ToString().ToLower() + ",""stateExact"":" + stateExact.ToString().ToLower() + ",""stateCompatible"":" + stateCompatible.ToString().ToLower() + ",""zipExact"":" + zipExact.ToString().ToLower() + ",""houseNumberExact"":" + houseNumberExact.ToString().ToLower() + ",""streetCoreExact"":" + streetCoreExact.ToString().ToLower() + ",""streetCoreNear"":" + streetCoreNear.ToString().ToLower() + ",""structuralAddressExact"":" + structuralAddressExact.ToString().ToLower() + ",""structuralAddressNear"":" + structuralAddressNear.ToString().ToLower() + ",""emailExact"":" + emailExact.ToString().ToLower() + ",""phoneExact"":" + phoneExact.ToString().ToLower() + ",""identityCompleteness"":" + identityCompleteness.ToString() + ",""scoreValue"":" + scoreValue.ToString() + ",""rejected"":" + rejected.ToString().ToLower() + ",""decision"":""" + decisionText + """}"]</InArgument>
