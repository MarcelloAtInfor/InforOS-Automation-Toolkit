        <OutArgument x:TypeArguments="x:String">[normalizedCandidateAddress]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">[(normalizedCandidateAddressLine1+" "+normalizedCandidateCity+" "+normalizedCandidateState+" "+normalizedCandidateZip).Trim()]</InArgument>
      </Assign.Value>
    </Assign>
    <Assign DisplayName="Normalize Candidate House Number" sap2010:WorkflowViewState.IdRef="Assign_2E">
      <Assign.To>
