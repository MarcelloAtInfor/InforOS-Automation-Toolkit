      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">[System.Text.RegularExpressions.Regex.Match(normalizedCandidateAddressLine1, "^\d+").Value]</InArgument>
      </Assign.Value>
    </Assign>
    <Assign DisplayName="Normalize Candidate Street Core" sap2010:WorkflowViewState.IdRef="Assign_2F">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">[normalizedCandidateStreetCore]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">[System.Text.RegularExpressions.Regex.Replace(normalizedCandidateAddressLine1, "^\d+\s*", "").Trim()]</InArgument>
      </Assign.Value>
    </Assign>
