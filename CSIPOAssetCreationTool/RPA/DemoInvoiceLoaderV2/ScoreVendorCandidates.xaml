      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">[System.Text.RegularExpressions.Regex.Replace(If(candidateZip Is Nothing, "", candidateZip.Trim()), "[^0-9]", "")]</InArgument>
      </Assign.Value>
    </Assign>
    <Assign DisplayName="Normalize Candidate Address" sap2010:WorkflowViewState.IdRef="Assign_2D">
