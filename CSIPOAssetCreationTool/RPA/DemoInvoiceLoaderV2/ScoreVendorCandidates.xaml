    <Assign DisplayName="Check Street Core Near" sap2010:WorkflowViewState.IdRef="Assign_7F">
      <Assign.To>
        <OutArgument x:TypeArguments="x:Boolean">[streetCoreNear]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:Boolean">[normalizedCandidateStreetCore &lt;&gt; "" AndAlso normalizedVendorStreetCore &lt;&gt; "" AndAlso Math.Abs(normalizedCandidateStreetCore.Length-normalizedVendorStreetCore.Length) &lt;= 2 AndAlso (Enumerable.Range(0, Math.Min(normalizedCandidateStreetCore.Length, normalizedVendorStreetCore.Length)).Count(Function(i) normalizedCandidateStreetCore.Substring(i,1) &lt;&gt; normalizedVendorStreetCore.Substring(i,1)) + Math.Abs(normalizedCandidateStreetCore.Length-normalizedVendorStreetCore.Length)) &lt;= 2]</InArgument>
      </Assign.Value>
    </Assign>
    <Assign DisplayName="Check Structural Address Exact" sap2010:WorkflowViewState.IdRef="Assign_7G">
