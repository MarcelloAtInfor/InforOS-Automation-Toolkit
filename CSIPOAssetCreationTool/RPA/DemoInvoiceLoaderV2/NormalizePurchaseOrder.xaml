<Activity mc:Ignorable="sap sap2010 sads" x:Class="RehostedWorkflowDesigner.Workflow"
 xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
 xmlns:ias="clr-namespace:Infor.Activities.Sys;assembly=Infor.Activities.Sys"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 xmlns:mva="clr-namespace:Microsoft.VisualBasic.Activities;assembly=System.Activities"
 xmlns:sads="http://schemas.microsoft.com/netfx/2010/xaml/activities/debugger"
 xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
 xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
 xmlns:scg="clr-namespace:System.Collections.Generic;assembly=mscorlib"
 xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=mscorlib"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <x:Members>
    <x:Property Name="rawPurchaseOrderNumber" Type="InArgument(x:String)" />
    <x:Property Name="logFile" Type="InArgument(x:String)" />
    <x:Property Name="normalizedPurchaseOrderNumber" Type="OutArgument(x:String)" />
    <x:Property Name="withinLengthLimit" Type="OutArgument(x:Boolean)" />
    <x:Property Name="normalizationStatus" Type="OutArgument(x:String)" />
    <x:Property Name="normalizationNote" Type="OutArgument(x:String)" />
  </x:Members>
  <mva:VisualBasic.Settings>
    <x:Null />
  </mva:VisualBasic.Settings>
  <sap2010:WorkflowViewState.IdRef>RehostedWorkflowDesigner.Workflow_1</sap2010:WorkflowViewState.IdRef>
  <TextExpression.NamespacesForImplementation>
    <sco:Collection x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.Activities</x:String>
      <x:String>System.Activities.Statements</x:String>
      <x:String>Microsoft.VisualBasic.Activities</x:String>
    </sco:Collection>
  </TextExpression.NamespacesForImplementation>
  <Sequence DisplayName="Normalize Purchase Order" sap2010:WorkflowViewState.IdRef="Sequence_1">
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="cleanPurchaseOrderNumber" />
    </Sequence.Variables>
    <Assign DisplayName="Clean Purchase Order Number" sap2010:WorkflowViewState.IdRef="Assign_1">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">[cleanPurchaseOrderNumber]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">[System.Text.RegularExpressions.Regex.Replace(If(rawPurchaseOrderNumber Is Nothing, "", rawPurchaseOrderNumber.Trim().ToUpper()), "[^A-Z0-9]", "")]</InArgument>
      </Assign.Value>
    </Assign>
    <Assign DisplayName="Output Normalized Number" sap2010:WorkflowViewState.IdRef="Assign_2">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">[normalizedPurchaseOrderNumber]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">[cleanPurchaseOrderNumber]</InArgument>
      </Assign.Value>
    </Assign>
    <Assign DisplayName="Check Length Limit" sap2010:WorkflowViewState.IdRef="Assign_3">
      <Assign.To>
        <OutArgument x:TypeArguments="x:Boolean">[withinLengthLimit]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:Boolean">[cleanPurchaseOrderNumber.Length &lt;= 10]</InArgument>
      </Assign.Value>
    </Assign>
    <Assign DisplayName="Set Normalization Status" sap2010:WorkflowViewState.IdRef="Assign_4">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">[normalizationStatus]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">[If(cleanPurchaseOrderNumber = "", "FAILED", If(cleanPurchaseOrderNumber.Length &lt;= 10, "SUCCESS", "REVIEW_REQUIRED"))]</InArgument>
      </Assign.Value>
    </Assign>
    <Assign DisplayName="Set Normalization Note" sap2010:WorkflowViewState.IdRef="Assign_5">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">[normalizationNote]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">[If(cleanPurchaseOrderNumber = "", "Purchase order number is empty after deterministic cleanup.", If(cleanPurchaseOrderNumber.Length &lt;= 10, "", "Purchase order number exceeds 10 characters after deterministic cleanup and requires an explicit shortening rule."))]</InArgument>
      </Assign.Value>
    </Assign>
    <ias:Append_Line ErrorCode="{x:Null}" ContinueOnError="True" DisplayName="Log PO Normalization" sap2010:WorkflowViewState.IdRef="Append_Line_1" Line="[System.Environment.NewLine+&quot;  NormalizePurchaseOrder:&quot;+System.Environment.NewLine+&quot;    Raw: &quot;+If(rawPurchaseOrderNumber Is Nothing, &quot;&quot;, rawPurchaseOrderNumber)+System.Environment.NewLine+&quot;    Normalized: &quot;+normalizedPurchaseOrderNumber+System.Environment.NewLine+&quot;    Status: &quot;+normalizationStatus+System.Environment.NewLine+&quot;    Note: &quot;+normalizationNote]" Source="[logFile]" />
  </Sequence>
  <sap2010:WorkflowViewState.ViewStateManager>
    <sap2010:ViewStateManager>
      <sap2010:ViewStateData Id="Assign_1" sap:VirtualizedContainerService.HintSize="432,60" />
      <sap2010:ViewStateData Id="Assign_2" sap:VirtualizedContainerService.HintSize="432,60" />
      <sap2010:ViewStateData Id="Assign_3" sap:VirtualizedContainerService.HintSize="432,60" />
      <sap2010:ViewStateData Id="Assign_4" sap:VirtualizedContainerService.HintSize="432,60" />
      <sap2010:ViewStateData Id="Assign_5" sap:VirtualizedContainerService.HintSize="432,60" />
      <sap2010:ViewStateData Id="Append_Line_1" sap:VirtualizedContainerService.HintSize="432,120" />
      <sap2010:ViewStateData Id="Sequence_1" sap:VirtualizedContainerService.HintSize="454,580">
        <sap:WorkflowViewStateService.ViewState>
          <scg:Dictionary x:TypeArguments="x:String, x:Object">
            <x:Boolean x:Key="IsExpanded">True</x:Boolean>
          </scg:Dictionary>
        </sap:WorkflowViewStateService.ViewState>
      </sap2010:ViewStateData>
      <sap2010:ViewStateData Id="RehostedWorkflowDesigner.Workflow_1" sap:VirtualizedContainerService.HintSize="494,660" />
    </sap2010:ViewStateManager>
  </sap2010:WorkflowViewState.ViewStateManager>
</Activity>
