  <TryCatch DisplayName="Send Notification">
    <TryCatch.Variables>
      <Variable x:TypeArguments="x:String" Name="workflowEndpoint" />
      <Variable x:TypeArguments="x:String" Name="requestPayload" />
      <Variable x:TypeArguments="iru:ResponseObject" Name="apiResponse" />
      <Variable x:TypeArguments="x:Int32" Name="apiResponseCode" />
      <Variable x:TypeArguments="x:String" Name="instanceName" />
      <Variable x:TypeArguments="x:String" Name="safeErrorMessage" />
      <Variable x:TypeArguments="x:String" Name="safeVendorNumber" />
      <Variable x:TypeArguments="x:String" Name="safeVendorName" />
      <Variable x:TypeArguments="x:String" Name="safePoNumber" />
      <Variable x:TypeArguments="x:String" Name="safeItemsCreated" />
      <Variable x:TypeArguments="x:String" Name="safeItemCount" />
      <Variable x:TypeArguments="njl:JArray" Name="resolvedItems" />
      <Variable x:TypeArguments="x:String" Name="currentItemCode" />
      <Variable x:TypeArguments="x:String" Name="safeItemCodes" />
      <Variable x:TypeArguments="x:String" Name="safeNotes" />
    </TryCatch.Variables>
    <TryCatch.Try>
      <Sequence>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[notificationStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["PENDING"]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[notificationError]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[""]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[safeErrorMessage]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(String.IsNullOrWhiteSpace(errorMessage), "N/A", errorMessage.Replace("\", "\\").Replace("""", "'").Replace(System.Environment.NewLine, " "))]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[safeVendorNumber]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(String.IsNullOrWhiteSpace(vendorNumber), "N/A", vendorNumber)]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[safeVendorName]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(String.IsNullOrWhiteSpace(vendorName), "N/A", vendorName.Replace("\", "\\").Replace("""", "'").Replace(System.Environment.NewLine, " "))]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[safePoNumber]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(String.IsNullOrWhiteSpace(poNumber), "N/A", poNumber)]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[safeItemsCreated]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(String.IsNullOrWhiteSpace(itemsCreated), "0", itemsCreated)]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[safeItemCount]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(String.IsNullOrWhiteSpace(itemCount), "0", itemCount)]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="njl:JArray">[resolvedItems]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="njl:JArray">[If(String.IsNullOrWhiteSpace(resolvedItemsJson), New JArray(), JArray.Parse(resolvedItemsJson))]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[safeItemCodes]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["N/A"]</InArgument></Assign.Value></Assign>
        <If Condition="[resolvedItems IsNot Nothing AndAlso resolvedItems.Count &gt; 0]">
          <If.Then>
            <Sequence>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[safeItemCodes]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[""]</InArgument></Assign.Value></Assign>
              <ForEach x:TypeArguments="njl:JToken" Values="[resolvedItems]">
                <ActivityAction x:TypeArguments="njl:JToken">
                  <ActivityAction.Argument>
                    <DelegateInArgument x:TypeArguments="njl:JToken" Name="resolvedItem" />
                  </ActivityAction.Argument>
                  <Sequence>
                    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[currentItemCode]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(resolvedItem("itemCode") IsNot Nothing, resolvedItem("itemCode").ToString().Trim(), "")]</InArgument></Assign.Value></Assign>
                    <If Condition="[Not String.IsNullOrWhiteSpace(currentItemCode)]">
                      <If.Then>
                        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[safeItemCodes]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(String.IsNullOrWhiteSpace(safeItemCodes), currentItemCode, safeItemCodes + ", " + currentItemCode)]</InArgument></Assign.Value></Assign>
                      </If.Then>
                    </If>
                  </Sequence>
                </ActivityAction>
              </ForEach>
              <If Condition="[String.IsNullOrWhiteSpace(safeItemCodes)]">
                <If.Then>
                  <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[safeItemCodes]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["N/A"]</InArgument></Assign.Value></Assign>
                </If.Then>
              </If>
            </Sequence>
          </If.Then>
        </If>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[safeNotes]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(String.IsNullOrWhiteSpace(notes), "N/A", notes.Replace("\", "\\").Replace("""", "'").Replace(System.Environment.NewLine, " "))]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[instanceName]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["RPA_"+System.DateTime.Now.ToString("yyyyMMdd_HHmmss")]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[workflowEndpoint]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[tenantURL.TrimEnd("/"c)+"/IONSERVICES/process/application/v1/workflow/start?logicalId=lid://infor.rpa.claudecode"]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[requestPayload]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["{""workflowName"": ""RPA_Invoice_Notification"", ""instanceName"": """+instanceName+""", ""inputVariables"": [{""name"": ""RecipientUserId"", ""value"": """+recipientUserId+""", ""dataType"": ""STRING""}, {""name"": ""ProcessingStatus"", ""value"": """+processingStatus+""", ""dataType"": ""STRING""}, {""name"": ""ErrorMessage"", ""value"": """+safeErrorMessage+""", ""dataType"": ""STRING""}, {""name"": ""FileName"", ""value"": """+fileName+""", ""dataType"": ""STRING""}, {""name"": ""VendorNumber"", ""value"": """+safeVendorNumber+""", ""dataType"": ""STRING""}, {""name"": ""VendorName"", ""value"": """+safeVendorName+""", ""dataType"": ""STRING""}, {""name"": ""PONumber"", ""value"": """+safePoNumber+""", ""dataType"": ""STRING""}, {""name"": ""ItemsCreated"", ""value"": """+safeItemsCreated+""", ""dataType"": ""STRING""}, {""name"": ""ItemCount"", ""value"": """+safeItemCount+""", ""dataType"": ""STRING""}, {""name"": ""Notes"", ""value"": """+safeNotes+""", ""dataType"": ""STRING""}], ""inputStructures"": [{""name"": ""CreatedAssets"", ""subStructures"": [{""name"": ""VendorInfo"", ""fields"": [{""name"": ""VendorNumber"", ""value"": """+safeVendorNumber+""", ""dataType"": ""STRING""}, {""name"": ""VendorName"", ""value"": """+safeVendorName+""", ""dataType"": ""STRING""}]}, {""name"": ""POInfo"", ""fields"": [{""name"": ""PONumber"", ""value"": """+safePoNumber+""", ""dataType"": ""STRING""}]}, {""name"": ""ItemsInfo"", ""fields"": [{""name"": ""ItemCount"", ""value"": """+safeItemCount+""", ""dataType"": ""STRING""}, {""name"": ""ItemsCreated"", ""value"": """+safeItemCodes+""", ""dataType"": ""STRING""}]}]}]}"]</InArgument></Assign.Value></Assign>
        <ias:Append_Line ErrorCode="{x:Null}" ContinueOnError="True" DisplayName="Log Notification Start" Line="[System.Environment.NewLine+&quot;  SendNotification:&quot;+System.Environment.NewLine+&quot;    Instance: &quot;+instanceName+System.Environment.NewLine+&quot;    Endpoint: &quot;+workflowEndpoint]" Source="[logFile]" />
        <iai:IONAPIRequestWizard FileAttachments="{x:Null}" QueryParameters="{x:Null}" StatusCode="{x:Null}" ContentType="application_json" ContinueOnError="True" DisplayName="POST Notification Workflow" HttpMethod="POST" PostData="[requestPayload]" Response="[apiResponse]" ResponseCode="[apiResponseCode]" Url="[workflowEndpoint]">
          <iai:IONAPIRequestWizard.Headers>
            <scg:List x:TypeArguments="scg:List(x:String)" Capacity="4">
              <scg:List x:TypeArguments="x:String" Capacity="0" />
              <scg:List x:TypeArguments="x:String" Capacity="0" />
            </scg:List>
          </iai:IONAPIRequestWizard.Headers>
        </iai:IONAPIRequestWizard>
        <If Condition="[apiResponseCode &gt;= 200 AndAlso apiResponseCode &lt; 300 AndAlso (apiResponse Is Nothing OrElse Not apiResponse.readastext.StartsWith(&quot;Code:&quot;))]">
          <If.Then>
            <Sequence>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[notificationStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["SUCCESS"]</InArgument></Assign.Value></Assign>
            </Sequence>
          </If.Then>
          <If.Else>
            <Sequence>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[notificationStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["FAILED"]</InArgument></Assign.Value></Assign>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[notificationError]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["API call failed with code "+apiResponseCode.ToString()+": "+If(apiResponse IsNot Nothing, apiResponse.readastext, "No response")]</InArgument></Assign.Value></Assign>
            </Sequence>
          </If.Else>
        </If>
      </Sequence>
    </TryCatch.Try>
    <TryCatch.Catches>
      <Catch x:TypeArguments="s:Exception">
        <ActivityAction x:TypeArguments="s:Exception">
          <ActivityAction.Argument>
            <DelegateInArgument x:TypeArguments="s:Exception" Name="exception" />
          </ActivityAction.Argument>
          <Sequence>
            <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[notificationStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["FAILED"]</InArgument></Assign.Value></Assign>
            <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[notificationError]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["Exception: "+exception.Message]</InArgument></Assign.Value></Assign>
          </Sequence>
        </ActivityAction>
      </Catch>
    </TryCatch.Catches>
  </TryCatch>
</Activity>
