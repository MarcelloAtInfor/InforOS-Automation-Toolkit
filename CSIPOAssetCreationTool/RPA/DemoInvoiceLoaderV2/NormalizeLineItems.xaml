<Activity mc:Ignorable="sap sap2010 sads" x:Class="RehostedWorkflowDesigner.Workflow"
 xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
 xmlns:ias="clr-namespace:Infor.Activities.Sys;assembly=Infor.Activities.Sys"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 xmlns:mva="clr-namespace:Microsoft.VisualBasic.Activities;assembly=System.Activities"
 xmlns:njl="clr-namespace:Newtonsoft.Json.Linq;assembly=Newtonsoft.Json"
 xmlns:s="clr-namespace:System;assembly=mscorlib"
 xmlns:sads="http://schemas.microsoft.com/netfx/2010/xaml/activities/debugger"
 xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
 xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
 xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=mscorlib"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <x:Members>
    <x:Property Name="lineItemsJson" Type="InArgument(x:String)" />
    <x:Property Name="logFile" Type="InArgument(x:String)" />
    <x:Property Name="normalizedLineItemsJson" Type="OutArgument(x:String)" />
    <x:Property Name="normalizationStatus" Type="OutArgument(x:String)" />
    <x:Property Name="normalizationErrorMessage" Type="OutArgument(x:String)" />
    <x:Property Name="normalizedLineCount" Type="OutArgument(x:Int32)" />
  </x:Members>
  <mva:VisualBasic.Settings>
    <x:Null />
  </mva:VisualBasic.Settings>
  <sap2010:WorkflowViewState.IdRef>RehostedWorkflowDesigner.Workflow_1</sap2010:WorkflowViewState.IdRef>
  <TextExpression.NamespacesForImplementation>
    <sco:Collection x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.Activities</x:String>
      <x:String>System.Activities.Statements</x:String>
      <x:String>Microsoft.VisualBasic.Activities</x:String>
      <x:String>Newtonsoft.Json.Linq</x:String>
    </sco:Collection>
  </TextExpression.NamespacesForImplementation>
  <TextExpression.ReferencesForImplementation>
    <sco:Collection x:TypeArguments="AssemblyReference">
      <AssemblyReference>System.Activities</AssemblyReference>
      <AssemblyReference>mscorlib</AssemblyReference>
      <AssemblyReference>System.Core</AssemblyReference>
      <AssemblyReference>PresentationFramework</AssemblyReference>
      <AssemblyReference>WindowsBase</AssemblyReference>
      <AssemblyReference>PresentationCore</AssemblyReference>
      <AssemblyReference>System.Xaml</AssemblyReference>
      <AssemblyReference>System</AssemblyReference>
      <AssemblyReference>Newtonsoft.Json</AssemblyReference>
      <AssemblyReference>System.ComponentModel.Composition</AssemblyReference>
    </sco:Collection>
  </TextExpression.ReferencesForImplementation>
  <TryCatch DisplayName="Normalize Line Items">
    <TryCatch.Variables>
      <Variable x:TypeArguments="njl:JArray" Name="inputItems" />
      <Variable x:TypeArguments="x:String" Name="outputFragments" />
      <Variable x:TypeArguments="x:String" Name="normalizedItemJson" />
      <Variable x:TypeArguments="x:String" Name="lineNumberValue" />
      <Variable x:TypeArguments="x:String" Name="itemCodeValue" />
      <Variable x:TypeArguments="x:String" Name="descriptionValue" />
      <Variable x:TypeArguments="x:String" Name="quantityValue" />
      <Variable x:TypeArguments="x:String" Name="uomValue" />
      <Variable x:TypeArguments="x:String" Name="unitPriceValue" />
      <Variable x:TypeArguments="x:String" Name="productCodeValue" />
    </TryCatch.Variables>
    <TryCatch.Try>
      <Sequence>
        <Assign>
          <Assign.To><OutArgument x:TypeArguments="x:String">[normalizationStatus]</OutArgument></Assign.To>
          <Assign.Value><InArgument x:TypeArguments="x:String">["PENDING"]</InArgument></Assign.Value>
        </Assign>
        <Assign>
          <Assign.To><OutArgument x:TypeArguments="x:String">[normalizationErrorMessage]</OutArgument></Assign.To>
          <Assign.Value><InArgument x:TypeArguments="x:String">[""]</InArgument></Assign.Value>
        </Assign>
        <Assign>
          <Assign.To><OutArgument x:TypeArguments="x:Int32">[normalizedLineCount]</OutArgument></Assign.To>
          <Assign.Value><InArgument x:TypeArguments="x:Int32">[0]</InArgument></Assign.Value>
        </Assign>
        <Assign>
          <Assign.To><OutArgument x:TypeArguments="x:String">[outputFragments]</OutArgument></Assign.To>
          <Assign.Value><InArgument x:TypeArguments="x:String">[""]</InArgument></Assign.Value>
        </Assign>
        <Assign>
          <Assign.To><OutArgument x:TypeArguments="njl:JArray">[inputItems]</OutArgument></Assign.To>
          <Assign.Value><InArgument x:TypeArguments="njl:JArray">[If(String.IsNullOrWhiteSpace(lineItemsJson), New JArray(), JArray.Parse(lineItemsJson))]</InArgument></Assign.Value>
        </Assign>
        <If Condition="[inputItems.Count = 0]">
          <If.Then>
            <Sequence>
              <Assign>
                <Assign.To><OutArgument x:TypeArguments="x:String">[normalizationStatus]</OutArgument></Assign.To>
                <Assign.Value><InArgument x:TypeArguments="x:String">["FAILED"]</InArgument></Assign.Value>
              </Assign>
              <Assign>
                <Assign.To><OutArgument x:TypeArguments="x:String">[normalizationErrorMessage]</OutArgument></Assign.To>
                <Assign.Value><InArgument x:TypeArguments="x:String">["No line items were provided for normalization."]</InArgument></Assign.Value>
              </Assign>
              <Assign>
                <Assign.To><OutArgument x:TypeArguments="x:String">[normalizedLineItemsJson]</OutArgument></Assign.To>
                <Assign.Value><InArgument x:TypeArguments="x:String">["[]"]</InArgument></Assign.Value>
              </Assign>
            </Sequence>
          </If.Then>
          <If.Else>
            <Sequence>
              <ForEach x:TypeArguments="njl:JToken" Values="[inputItems]">
                <ActivityAction x:TypeArguments="njl:JToken">
                  <ActivityAction.Argument>
                    <DelegateInArgument x:TypeArguments="njl:JToken" Name="lineItem" />
                  </ActivityAction.Argument>
                  <Sequence>
                    <Assign>
                      <Assign.To><OutArgument x:TypeArguments="x:String">[lineNumberValue]</OutArgument></Assign.To>
                      <Assign.Value><InArgument x:TypeArguments="x:String">[If(lineItem("lineNumber") IsNot Nothing AndAlso Not String.IsNullOrWhiteSpace(lineItem("lineNumber").ToString()), lineItem("lineNumber").ToString().Trim(), (normalizedLineCount + 1).ToString())]</InArgument></Assign.Value>
                    </Assign>
                    <Assign>
                      <Assign.To><OutArgument x:TypeArguments="x:String">[itemCodeValue]</OutArgument></Assign.To>
                      <Assign.Value><InArgument x:TypeArguments="x:String">[If(lineItem("itemCode") IsNot Nothing, lineItem("itemCode").ToString().Trim().ToUpper(), "")]</InArgument></Assign.Value>
                    </Assign>
                    <Assign>
                      <Assign.To><OutArgument x:TypeArguments="x:String">[descriptionValue]</OutArgument></Assign.To>
                      <Assign.Value><InArgument x:TypeArguments="x:String">[If(lineItem("description") IsNot Nothing, lineItem("description").ToString().Trim(), "")]</InArgument></Assign.Value>
                    </Assign>
                    <Assign>
                      <Assign.To><OutArgument x:TypeArguments="x:String">[quantityValue]</OutArgument></Assign.To>
                      <Assign.Value><InArgument x:TypeArguments="x:String">[If(lineItem("quantity") IsNot Nothing AndAlso Not String.IsNullOrWhiteSpace(lineItem("quantity").ToString()), lineItem("quantity").ToString().Replace(",","").Trim(), "1")]</InArgument></Assign.Value>
                    </Assign>
                    <Assign>
                      <Assign.To><OutArgument x:TypeArguments="x:String">[quantityValue]</OutArgument></Assign.To>
                      <Assign.Value><InArgument x:TypeArguments="x:String">[If(quantityValue.Contains("."), quantityValue, quantityValue + ".00")]</InArgument></Assign.Value>
                    </Assign>
                    <Assign>
                      <Assign.To><OutArgument x:TypeArguments="x:String">[uomValue]</OutArgument></Assign.To>
                      <Assign.Value><InArgument x:TypeArguments="x:String">[If(lineItem("unitOfMeasure") IsNot Nothing AndAlso Not String.IsNullOrWhiteSpace(lineItem("unitOfMeasure").ToString()), lineItem("unitOfMeasure").ToString().Trim().ToUpper(), "EA")]</InArgument></Assign.Value>
                    </Assign>
                    <Assign>
                      <Assign.To><OutArgument x:TypeArguments="x:String">[unitPriceValue]</OutArgument></Assign.To>
                      <Assign.Value><InArgument x:TypeArguments="x:String">[If(lineItem("unitPrice") IsNot Nothing AndAlso Not String.IsNullOrWhiteSpace(lineItem("unitPrice").ToString()), lineItem("unitPrice").ToString().Replace("$","").Replace(",","").Trim(), "0.00")]</InArgument></Assign.Value>
                    </Assign>
                    <Assign>
                      <Assign.To><OutArgument x:TypeArguments="x:String">[productCodeValue]</OutArgument></Assign.To>
                      <Assign.Value><InArgument x:TypeArguments="x:String">[If(lineItem("productCode") IsNot Nothing AndAlso Not String.IsNullOrWhiteSpace(lineItem("productCode").ToString()), lineItem("productCode").ToString().Trim().ToUpper(), "FG-100")]</InArgument></Assign.Value>
                    </Assign>
                    <Assign>
                      <Assign.To><OutArgument x:TypeArguments="x:String">[normalizedItemJson]</OutArgument></Assign.To>
                      <Assign.Value><InArgument x:TypeArguments="x:String">["{""lineNumber"":""" + lineNumberValue.Replace("""","") + """,""itemCode"":""" + itemCodeValue.Replace("""","") + """,""description"":""" + descriptionValue.Replace("""","'") + """,""quantity"":""" + quantityValue.Replace("""","") + """,""unitOfMeasure"":""" + uomValue.Replace("""","") + """,""unitPrice"":""" + unitPriceValue.Replace("""","") + """,""productCode"":""" + productCodeValue.Replace("""","") + """}"]</InArgument></Assign.Value>
                    </Assign>
                    <Assign>
                      <Assign.To><OutArgument x:TypeArguments="x:String">[outputFragments]</OutArgument></Assign.To>
                      <Assign.Value><InArgument x:TypeArguments="x:String">[outputFragments + If(String.IsNullOrWhiteSpace(outputFragments), "", ",") + normalizedItemJson]</InArgument></Assign.Value>
                    </Assign>
                    <Assign>
                      <Assign.To><OutArgument x:TypeArguments="x:Int32">[normalizedLineCount]</OutArgument></Assign.To>
                      <Assign.Value><InArgument x:TypeArguments="x:Int32">[normalizedLineCount + 1]</InArgument></Assign.Value>
                    </Assign>
                  </Sequence>
                </ActivityAction>
              </ForEach>
              <Assign>
                <Assign.To><OutArgument x:TypeArguments="x:String">[normalizedLineItemsJson]</OutArgument></Assign.To>
                <Assign.Value><InArgument x:TypeArguments="x:String">["[" + outputFragments + "]"]</InArgument></Assign.Value>
              </Assign>
              <Assign>
                <Assign.To><OutArgument x:TypeArguments="x:String">[normalizationStatus]</OutArgument></Assign.To>
                <Assign.Value><InArgument x:TypeArguments="x:String">["SUCCESS"]</InArgument></Assign.Value>
              </Assign>
              <ias:Append_Line ContinueOnError="True" ErrorCode="{x:Null}" DisplayName="Log Normalized Line Summary" Line="[System.Environment.NewLine+&quot;  NormalizeLineItems:&quot;+System.Environment.NewLine+&quot;    InputCount: &quot;+inputItems.Count.ToString()+System.Environment.NewLine+&quot;    OutputCount: &quot;+normalizedLineCount.ToString()+System.Environment.NewLine+&quot;    Status: &quot;+normalizationStatus]" Source="[logFile]" />
            </Sequence>
          </If.Else>
        </If>
      </Sequence>
    </TryCatch.Try>
    <TryCatch.Catches>
      <Catch x:TypeArguments="s:Exception">
        <ActivityAction x:TypeArguments="s:Exception">
          <ActivityAction.Argument>
            <DelegateInArgument x:TypeArguments="s:Exception" Name="exception" />
          </ActivityAction.Argument>
          <Sequence>
            <Assign>
              <Assign.To><OutArgument x:TypeArguments="x:String">[normalizationStatus]</OutArgument></Assign.To>
              <Assign.Value><InArgument x:TypeArguments="x:String">["FAILED"]</InArgument></Assign.Value>
            </Assign>
            <Assign>
              <Assign.To><OutArgument x:TypeArguments="x:String">[normalizationErrorMessage]</OutArgument></Assign.To>
              <Assign.Value><InArgument x:TypeArguments="x:String">["Line item normalization exception: " + exception.Message]</InArgument></Assign.Value>
            </Assign>
            <Assign>
              <Assign.To><OutArgument x:TypeArguments="x:String">[normalizedLineItemsJson]</OutArgument></Assign.To>
              <Assign.Value><InArgument x:TypeArguments="x:String">["[]"]</InArgument></Assign.Value>
            </Assign>
          </Sequence>
        </ActivityAction>
      </Catch>
    </TryCatch.Catches>
  </TryCatch>
</Activity>
