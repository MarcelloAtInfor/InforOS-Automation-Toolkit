<Activity mc:Ignorable="sap sap2010 sads" x:Class="RehostedWorkflowDesigner.Workflow"
 xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
 xmlns:iao="clr-namespace:Infor.Activities.OCR;assembly=Infor.Activities.OCR"
 xmlns:ias="clr-namespace:Infor.Activities.Sys;assembly=Infor.Activities.Sys"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 xmlns:mva="clr-namespace:Microsoft.VisualBasic.Activities;assembly=System.Activities"
 xmlns:njl="clr-namespace:Newtonsoft.Json.Linq;assembly=Newtonsoft.Json"
 xmlns:s="clr-namespace:System;assembly=mscorlib"
 xmlns:sads="http://schemas.microsoft.com/netfx/2010/xaml/activities/debugger"
 xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
 xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=mscorlib"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <x:Members>
    <x:Property Name="documentPath" Type="InArgument(x:String)" />
    <x:Property Name="rawOcrJsonOverride" Type="InArgument(x:String)" />
    <x:Property Name="rawOcrJsonPath" Type="InArgument(x:String)" />
    <x:Property Name="logFile" Type="InArgument(x:String)" />
    <x:Property Name="ocrStatus" Type="OutArgument(x:String)" />
    <x:Property Name="ocrErrorMessage" Type="OutArgument(x:String)" />
    <x:Property Name="ocrJsonText" Type="OutArgument(x:String)" />
    <x:Property Name="ocrMode" Type="OutArgument(x:String)" />
    <x:Property Name="resolvedSourceDocumentName" Type="OutArgument(x:String)" />
  </x:Members>
  <mva:VisualBasic.Settings>
    <x:Null />
  </mva:VisualBasic.Settings>
  <sap2010:WorkflowViewState.IdRef>RehostedWorkflowDesigner.Workflow_1</sap2010:WorkflowViewState.IdRef>
  <TextExpression.NamespacesForImplementation>
    <sco:Collection x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.Activities</x:String>
      <x:String>System.Activities.Statements</x:String>
      <x:String>Infor.Activities.OCR</x:String>
      <x:String>Microsoft.VisualBasic.Activities</x:String>
      <x:String>Newtonsoft.Json.Linq</x:String>
    </sco:Collection>
  </TextExpression.NamespacesForImplementation>
  <TextExpression.ReferencesForImplementation>
    <sco:Collection x:TypeArguments="AssemblyReference">
      <AssemblyReference>System.Activities</AssemblyReference>
      <AssemblyReference>Infor.Activities.OCR</AssemblyReference>
      <AssemblyReference>Newtonsoft.Json</AssemblyReference>
      <AssemblyReference>mscorlib</AssemblyReference>
      <AssemblyReference>System.Core</AssemblyReference>
      <AssemblyReference>PresentationFramework</AssemblyReference>
      <AssemblyReference>WindowsBase</AssemblyReference>
      <AssemblyReference>PresentationCore</AssemblyReference>
      <AssemblyReference>System.Xaml</AssemblyReference>
      <AssemblyReference>System</AssemblyReference>
      <AssemblyReference>System.ComponentModel.Composition</AssemblyReference>
      <AssemblyReference>System.Memory</AssemblyReference>
      <AssemblyReference>System.ValueTuple</AssemblyReference>
      <AssemblyReference>System.Runtime.WindowsRuntime</AssemblyReference>
    </sco:Collection>
  </TextExpression.ReferencesForImplementation>
  <TryCatch DisplayName="Extract OCR Data">
    <TryCatch.Variables>
      <Variable x:TypeArguments="x:String" Name="effectiveOcrJsonText" />
      <Variable x:TypeArguments="x:String" Name="derivedOcrJsonPath" />
      <Variable x:TypeArguments="njl:JToken" Name="liveOcrResponse" />
      <Variable x:TypeArguments="x:Int32" Name="liveOcrErrorCode" />
    </TryCatch.Variables>
    <TryCatch.Try>
      <Sequence>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[ocrStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["PENDING"]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[ocrErrorMessage]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[""]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[ocrJsonText]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[""]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[ocrMode]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["UNSET"]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[resolvedSourceDocumentName]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(Not String.IsNullOrWhiteSpace(documentPath), System.IO.Path.GetFileName(documentPath), If(Not String.IsNullOrWhiteSpace(rawOcrJsonPath), System.IO.Path.GetFileName(rawOcrJsonPath), "inline-ocr-json"))]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[derivedOcrJsonPath]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(Not String.IsNullOrWhiteSpace(documentPath), System.IO.Path.ChangeExtension(documentPath, ".json"), "")]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[effectiveOcrJsonText]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(Not String.IsNullOrWhiteSpace(rawOcrJsonOverride), rawOcrJsonOverride, If(Not String.IsNullOrWhiteSpace(rawOcrJsonPath), System.IO.File.ReadAllText(rawOcrJsonPath), If(Not String.IsNullOrWhiteSpace(derivedOcrJsonPath) AndAlso System.IO.File.Exists(derivedOcrJsonPath), System.IO.File.ReadAllText(derivedOcrJsonPath), "")))]</InArgument></Assign.Value></Assign>
        <If Condition="[Not String.IsNullOrWhiteSpace(effectiveOcrJsonText)]">
          <If.Then>
            <Sequence>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[ocrJsonText]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[effectiveOcrJsonText]</InArgument></Assign.Value></Assign>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[ocrMode]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(Not String.IsNullOrWhiteSpace(rawOcrJsonOverride), "OVERRIDE_JSON", If(Not String.IsNullOrWhiteSpace(rawOcrJsonPath), "FILE_JSON_PATH", "DOCUMENT_SIDECAR_JSON"))]</InArgument></Assign.Value></Assign>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[ocrStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["SUCCESS"]</InArgument></Assign.Value></Assign>
              <ias:Append_Line ContinueOnError="True" ErrorCode="{x:Null}" DisplayName="Log OCR Override Path" Line="[System.Environment.NewLine+&quot;  ExtractOCRData:&quot;+System.Environment.NewLine+&quot;    Mode: &quot;+If(Not String.IsNullOrWhiteSpace(rawOcrJsonOverride), &quot;OVERRIDE_JSON&quot;, If(Not String.IsNullOrWhiteSpace(rawOcrJsonPath), &quot;FILE_JSON_PATH&quot;, &quot;DOCUMENT_SIDECAR_JSON&quot;))+System.Environment.NewLine+&quot;    Document: &quot;+If(String.IsNullOrWhiteSpace(documentPath), &quot;N/A&quot;, documentPath)+If(String.IsNullOrWhiteSpace(rawOcrJsonPath) AndAlso String.IsNullOrWhiteSpace(derivedOcrJsonPath), &quot;&quot;, System.Environment.NewLine+&quot;    SourceJsonPath: &quot;+If(Not String.IsNullOrWhiteSpace(rawOcrJsonPath), rawOcrJsonPath, derivedOcrJsonPath))]" Source="[logFile]" />
            </Sequence>
          </If.Then>
          <If.Else>
            <Sequence>
              <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[ocrMode]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["LIVE_ACTIVITY"]</InArgument></Assign.Value></Assign>
              <ias:Append_Line ContinueOnError="True" ErrorCode="{x:Null}" DisplayName="Log Live OCR Activity" Line="[System.Environment.NewLine+&quot;  ExtractOCRData:&quot;+System.Environment.NewLine+&quot;    Mode: LIVE_ACTIVITY&quot;+System.Environment.NewLine+&quot;    Document: &quot;+If(String.IsNullOrWhiteSpace(documentPath), &quot;N/A&quot;, documentPath)+System.Environment.NewLine+&quot;    Step: Live OCR Activity&quot;]" Source="[logFile]" />
              <iao:ExtractDataActivity ActivityID="2f5f6ec0-3290-49e9-b14f-7a6f34f3c8f4" ContinueOnError="True" DisplayName="Live OCR Activity" DocumentPath="[documentPath]" ErrorCode="[liveOcrErrorCode]" ExecuteFile="True" OcrType="2" ResponseObject="[liveOcrResponse]" />
              <If Condition="[liveOcrResponse Is Nothing]">
                <If.Then>
                  <Sequence>
                    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[ocrStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["FAILED"]</InArgument></Assign.Value></Assign>
                    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[ocrErrorMessage]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["Live OCR returned no response. Check the Studio OCR activity binding. ErrorCode: " + liveOcrErrorCode.ToString()]</InArgument></Assign.Value></Assign>
                  </Sequence>
                </If.Then>
                <If.Else>
                  <Sequence>
                    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[ocrJsonText]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[liveOcrResponse.ToString()]</InArgument></Assign.Value></Assign>
                    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[ocrStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["SUCCESS"]</InArgument></Assign.Value></Assign>
                  </Sequence>
                </If.Else>
              </If>
            </Sequence>
          </If.Else>
        </If>
      </Sequence>
    </TryCatch.Try>
    <TryCatch.Catches>
      <Catch x:TypeArguments="s:Exception">
        <ActivityAction x:TypeArguments="s:Exception">
          <ActivityAction.Argument>
            <DelegateInArgument x:TypeArguments="s:Exception" Name="exception" />
          </ActivityAction.Argument>
          <Sequence>
            <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[ocrStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["FAILED"]</InArgument></Assign.Value></Assign>
            <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[ocrMode]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["EXCEPTION"]</InArgument></Assign.Value></Assign>
            <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[ocrErrorMessage]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["ExtractOCRData exception: " + exception.Message]</InArgument></Assign.Value></Assign>
          </Sequence>
        </ActivityAction>
      </Catch>
    </TryCatch.Catches>
  </TryCatch>
</Activity>
