                <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[priceValue]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(lineItem("unitPrice") IsNot Nothing, lineItem("unitPrice").ToString().Trim(), "0.00")]</InArgument></Assign.Value></Assign>
                <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[productCodeValue]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(lineItem("productCode") IsNot Nothing, lineItem("productCode").ToString().Trim(), "FG-100")]</InArgument></Assign.Value></Assign>
                <iaw:InvokeWorkflow Arguments="[New Dictionary(Of String, Object) From {{&quot;projectPath&quot;,projectPath},{&quot;tenantURL&quot;,tenantURL},{&quot;site&quot;,site},{&quot;itemCode&quot;,itemCodeValue},{&quot;description&quot;,descriptionValue},{&quot;unitOfMeasure&quot;,uomValue},{&quot;unitPrice&quot;,priceValue},{&quot;productCode&quot;,productCodeValue},{&quot;logFile&quot;,logFile}}]" ContinueOnError="False" DisplayName="Resolve Item" sap2010:WorkflowViewState.IdRef="InvokeWorkflow_1" OutputArguments="[itemOutput]" ResponseCode="{x:Null}" WorkflowFile="[projectPath+&quot;\ResolveItemDecision.xaml&quot;]" />
                <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[itemStatusLocal]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[itemOutput("resolvedStatus").ToString()]</InArgument></Assign.Value></Assign>
                <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[resolvedItemCodeLocal]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[itemOutput("resolvedItemCode").ToString()]</InArgument></Assign.Value></Assign>
