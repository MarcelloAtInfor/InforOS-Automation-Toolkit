                <Assign><Assign.To><OutArgument x:TypeArguments="x:Boolean">[itemCreatedLocal]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:Boolean">[CBool(itemOutput("createdFlag").ToString())]</InArgument></Assign.Value></Assign>
                <If Condition="[itemCreatedLocal]">
                  <If.Then>
                    <Assign><Assign.To><OutArgument x:TypeArguments="x:Int32">[createdItemCount]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:Int32">[createdItemCount + 1]</InArgument></Assign.Value></Assign>
