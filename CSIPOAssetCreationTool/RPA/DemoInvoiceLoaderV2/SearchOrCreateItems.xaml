                <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[resolvedUomLocal]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[itemOutput("resolvedUnitOfMeasure").ToString()]</InArgument></Assign.Value></Assign>
