    <x:Property Name="tenantURL" Type="InArgument(x:String)" />
    <x:Property Name="site" Type="InArgument(x:String)" />
    <x:Property Name="purchaseOrderNumber" Type="InArgument(x:String)" />
    <x:Property Name="logFile" Type="InArgument(x:String)" />
    <x:Property Name="verificationStatus" Type="OutArgument(x:String)" />
    <x:Property Name="verificationResponseJson" Type="OutArgument(x:String)" />
    <x:Property Name="verificationErrorMessage" Type="OutArgument(x:String)" />
  </x:Members>
  <mva:VisualBasic.Settings>
    <x:Null />
  </mva:VisualBasic.Settings>
  <sap2010:WorkflowViewState.IdRef>RehostedWorkflowDesigner.Workflow_1</sap2010:WorkflowViewState.IdRef>
  <TextExpression.NamespacesForImplementation>
    <sco:Collection x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.Activities</x:String>
      <x:String>System.Activities.Statements</x:String>
      <x:String>Microsoft.VisualBasic.Activities</x:String>
      <x:String>System.Collections.Generic</x:String>
    </sco:Collection>
  </TextExpression.NamespacesForImplementation>
  <Sequence DisplayName="Verify Purchase Order" sap2010:WorkflowViewState.IdRef="Sequence_1">
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="queryFilter" />
      <Variable x:TypeArguments="x:String" Name="queryResponseJson" />
      <Variable x:TypeArguments="x:String" Name="queryStatus" />
      <Variable x:TypeArguments="x:String" Name="queryError" />
      <Variable x:TypeArguments="scg:IDictionary(x:String, x:Object)" Name="loadOutputDict" />
    </Sequence.Variables>
    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[verificationStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["PENDING"]</InArgument></Assign.Value></Assign>
    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[verificationErrorMessage]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[""]</InArgument></Assign.Value></Assign>
    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[queryFilter]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["PoNum = '"+If(purchaseOrderNumber Is Nothing, "", purchaseOrderNumber.Replace("'", "''").Trim().ToUpper())+"'"]</InArgument></Assign.Value></Assign>
    <iaw:InvokeWorkflow Arguments="[New Dictionary(Of String, Object) From {{&quot;tenantURL&quot;,tenantURL},{&quot;site&quot;,site},{&quot;idoName&quot;,&quot;SLPOs&quot;},{&quot;properties&quot;,&quot;PoNum,VendNum,TermsCode,Stat,Type,Whse,PoCurrCode,SalesTaxT,_ItemId&quot;},{&quot;filter&quot;,queryFilter},{&quot;orderBy&quot;,&quot;PoNum ASC&quot;},{&quot;recordCap&quot;,&quot;1&quot;},{&quot;logFile&quot;,logFile}}]" ContinueOnError="False" DisplayName="Execute Verify PO Load" sap2010:WorkflowViewState.IdRef="InvokeWorkflow_1" OutputArguments="[loadOutputDict]" ResponseCode="{x:Null}" WorkflowFile="[projectPath+&quot;\ExecuteIdoLoad.xaml&quot;]" />
    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[queryResponseJson]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(loadOutputDict IsNot Nothing AndAlso loadOutputDict.ContainsKey("responseJson"), loadOutputDict("responseJson").ToString(), "")]</InArgument></Assign.Value></Assign>
    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[queryStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(loadOutputDict IsNot Nothing AndAlso loadOutputDict.ContainsKey("operationStatus"), loadOutputDict("operationStatus").ToString(), "FAILED")]</InArgument></Assign.Value></Assign>
    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[queryError]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(loadOutputDict IsNot Nothing AndAlso loadOutputDict.ContainsKey("errorMessage"), loadOutputDict("errorMessage").ToString(), "")]</InArgument></Assign.Value></Assign>
    <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[verificationResponseJson]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[queryResponseJson]</InArgument></Assign.Value></Assign>
    <ias:Append_Line ErrorCode="{x:Null}" ContinueOnError="True" DisplayName="Log PO Verify Summary" sap2010:WorkflowViewState.IdRef="Append_Line_1" Line="[System.Environment.NewLine+&quot;  VerifyPurchaseOrder:&quot;+System.Environment.NewLine+&quot;    PoNum: &quot;+purchaseOrderNumber+System.Environment.NewLine+&quot;    Status: &quot;+queryStatus+If(queryError.Length &gt; 0, System.Environment.NewLine+&quot;    Error: &quot;+queryError, &quot;&quot;)]" Source="[logFile]" />
    <If Condition="[queryStatus = &quot;SUCCESS&quot; AndAlso queryResponseJson.Contains(&quot;&quot;&quot;PoNum&quot;&quot;:&quot;)]">
      <If.Then>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[verificationStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["SUCCESS"]</InArgument></Assign.Value></Assign>
      </If.Then>
      <If.Else>
        <Sequence>
          <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[verificationStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["FAILED"]</InArgument></Assign.Value></Assign>
          <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[verificationErrorMessage]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(queryStatus = "SUCCESS", "Purchase order verification query returned no matching PO row.", queryError)]</InArgument></Assign.Value></Assign>
        </Sequence>
      </If.Else>
    </If>
  </Sequence>
  <sap2010:WorkflowViewState.ViewStateManager>
    <sap2010:ViewStateManager>
      <sap2010:ViewStateData Id="InvokeWorkflow_1" sap:VirtualizedContainerService.HintSize="432,22" />
      <sap2010:ViewStateData Id="Append_Line_1" sap:VirtualizedContainerService.HintSize="432,120" />
      <sap2010:ViewStateData Id="If_1" sap:VirtualizedContainerService.HintSize="432,248" />
      <sap2010:ViewStateData Id="Sequence_1" sap:VirtualizedContainerService.HintSize="454,860" />
      <sap2010:ViewStateData Id="RehostedWorkflowDesigner.Workflow_1" sap:VirtualizedContainerService.HintSize="494,940" />
    </sap2010:ViewStateManager>
  </sap2010:WorkflowViewState.ViewStateManager>
</Activity>
