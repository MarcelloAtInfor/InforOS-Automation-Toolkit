<Activity mc:Ignorable="sap sap2010 sads" x:Class="RehostedWorkflowDesigner.Workflow"
 xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
 xmlns:ias="clr-namespace:Infor.Activities.Sys;assembly=Infor.Activities.Sys"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 xmlns:mva="clr-namespace:Microsoft.VisualBasic.Activities;assembly=System.Activities"
 xmlns:s="clr-namespace:System;assembly=mscorlib"
 xmlns:sads="http://schemas.microsoft.com/netfx/2010/xaml/activities/debugger"
 xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
 xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
 xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=mscorlib"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <x:Members>
    <x:Property Name="inputFolderPath" Type="InArgument(x:String)" />
    <x:Property Name="claimedDocumentPath" Type="InArgument(x:String)" />
    <x:Property Name="claimedJsonPath" Type="InArgument(x:String)" />
    <x:Property Name="processingStatus" Type="InArgument(x:String)" />
    <x:Property Name="logFile" Type="InArgument(x:String)" />
    <x:Property Name="finalizeStatus" Type="OutArgument(x:String)" />
    <x:Property Name="finalizeErrorMessage" Type="OutArgument(x:String)" />
  </x:Members>
  <mva:VisualBasic.Settings>
    <x:Null />
  </mva:VisualBasic.Settings>
  <TextExpression.NamespacesForImplementation>
    <sco:Collection x:TypeArguments="x:String">
      <x:String>System</x:String>
      <x:String>System.Activities</x:String>
      <x:String>System.Activities.Statements</x:String>
      <x:String>Microsoft.VisualBasic.Activities</x:String>
    </sco:Collection>
  </TextExpression.NamespacesForImplementation>
  <TryCatch DisplayName="Finalize Batch Document">
    <TryCatch.Variables>
      <Variable x:TypeArguments="x:String" Name="runtimeRootFolder" />
      <Variable x:TypeArguments="x:String" Name="targetFolder" />
      <Variable x:TypeArguments="x:String" Name="todayFolder" />
      <Variable x:TypeArguments="x:String" Name="documentTargetName" />
      <Variable x:TypeArguments="x:String" Name="jsonTargetName" />
      <Variable x:TypeArguments="x:Boolean" Name="claimedDocumentExists" />
      <Variable x:TypeArguments="x:Boolean" Name="claimedJsonExists" />
      <Variable x:TypeArguments="x:String" Name="moveOutput" />
    </TryCatch.Variables>
    <TryCatch.Try>
      <Sequence>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[finalizeStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["PENDING"]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[finalizeErrorMessage]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[""]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[todayFolder]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[System.DateTime.Now.ToString("yyyy-MM-dd")]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[runtimeRootFolder]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Directory.GetParent(inputFolderPath).FullName]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[targetFolder]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Path.Combine(runtimeRootFolder, If(String.Equals(processingStatus, "SUCCESS", StringComparison.OrdinalIgnoreCase), "Success", "Failure"), todayFolder)]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[documentTargetName]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(String.IsNullOrWhiteSpace(claimedDocumentPath), "", System.IO.Path.GetFileName(claimedDocumentPath))]</InArgument></Assign.Value></Assign>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[jsonTargetName]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(String.IsNullOrWhiteSpace(claimedJsonPath), "", System.IO.Path.GetFileName(claimedJsonPath))]</InArgument></Assign.Value></Assign>
        <ias:Path_Validate ErrorCode="{x:Null}" ContinueOnError="True" DisplayName="Check Claimed Document Exists" IsValid="[claimedDocumentExists]" Path="[claimedDocumentPath]" />
        <ias:Path_Validate ErrorCode="{x:Null}" ContinueOnError="True" DisplayName="Check Claimed Json Exists" IsValid="[claimedJsonExists]" Path="[claimedJsonPath]" />
        <If Condition="[claimedDocumentExists]">
          <If.Then>
            <ias:File_Move ErrorCode="{x:Null}" ContinueOnError="False" DisplayName="Move Document To Final Folder" OutputFile="[moveOutput]" OverwriteFile="True" Source="[claimedDocumentPath]" Target="[targetFolder]" targetName="[documentTargetName]" />
          </If.Then>
        </If>
        <If Condition="[claimedJsonExists]">
          <If.Then>
            <ias:File_Move ErrorCode="{x:Null}" ContinueOnError="False" DisplayName="Move Json To Final Folder" OutputFile="[moveOutput]" OverwriteFile="True" Source="[claimedJsonPath]" Target="[targetFolder]" targetName="[jsonTargetName]" />
          </If.Then>
        </If>
        <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[finalizeStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["SUCCESS"]</InArgument></Assign.Value></Assign>
        <ias:Append_Line ContinueOnError="True" ErrorCode="{x:Null}" DisplayName="Log Finalize Result" Line="[System.Environment.NewLine+&quot;  FinalizeBatchDocument:&quot;+System.Environment.NewLine+&quot;    ProcessingStatus: &quot;+processingStatus+System.Environment.NewLine+&quot;    TargetFolder: &quot;+targetFolder+System.Environment.NewLine+&quot;    DocumentMoved: &quot;+claimedDocumentExists.ToString()+System.Environment.NewLine+&quot;    JsonMoved: &quot;+claimedJsonExists.ToString()+System.Environment.NewLine+&quot;    Status: &quot;+finalizeStatus]" Source="[logFile]" />
      </Sequence>
    </TryCatch.Try>
    <TryCatch.Catches>
      <Catch x:TypeArguments="s:Exception">
        <ActivityAction x:TypeArguments="s:Exception">
          <ActivityAction.Argument>
            <DelegateInArgument x:TypeArguments="s:Exception" Name="exception" />
          </ActivityAction.Argument>
          <Sequence>
            <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[finalizeStatus]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["FAILED"]</InArgument></Assign.Value></Assign>
            <Assign><Assign.To><OutArgument x:TypeArguments="x:String">[finalizeErrorMessage]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["FinalizeBatchDocument exception: " + exception.Message]</InArgument></Assign.Value></Assign>
          </Sequence>
        </ActivityAction>
      </Catch>
    </TryCatch.Catches>
  </TryCatch>
</Activity>
