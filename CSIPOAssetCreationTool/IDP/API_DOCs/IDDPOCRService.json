  "definitions": {
    "GridFilters": {
      "type": "object",
      "properties": {
        "currentPage": {
          "format": "int32",
          "type": "integer"
        },
        "pageSize": {
          "format": "int32",
          "type": "integer"
        },
        "sortColumn": {
          "format": "string",
          "maxLength": 200,
          "minLength": 0,
          "type": "string"
        },
        "sortDirection": {
          "format": "string",
          "maxLength": 10,
          "minLength": 0,
          "pattern": "^(ASC|DESC|asc|desc|ascending|descending|ASCENDING|DESCENDING|)$",
          "type": "string"
        },
        "reqFilterExpression": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ReqFilterExpression"
          }
        }
      },
      "additionalProperties": false
    },
    "ReqFilterExpression": {
      "type": "object",
      "properties": {
        "columnId": {
          "format": "string",
          "maxLength": 200,
          "minLength": 0,
          "type": "string"
        },
        "filterOperator": {
          "format": "string",
          "maxLength": 50,
          "minLength": 0,
          "type": "string"
        },
        "value": {
          "format": "string",
          "maxLength": 2000,
          "minLength": 0,
          "type": "string"
        },
        "filterType": {
          "format": "string",
          "maxLength": 50,
          "minLength": 0,
          "type": "string"
        },
        "timeZone": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}