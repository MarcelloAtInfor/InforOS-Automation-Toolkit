          "multipart/form-data"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "list_of_keys",
            "description": "Comma seperated list of keys to search",
            "type": "string"
          },
          {
            "in": "path",
            "name": "ver",
            "required": true,
            "type": "string"
          },
          {
            "in": "formData",
            "name": "ocrDocument",
            "description": "Document path in which the keys need to be searched",
            "type": "file"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/ocrsvc/v{ver}/AsyncDocumentOCR": {
      "post": {
        "tags": [
