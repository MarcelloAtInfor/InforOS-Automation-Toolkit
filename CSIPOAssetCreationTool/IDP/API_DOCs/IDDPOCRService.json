          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/ocrsvc/v{ver}/AsyncDocumentExtraction": {
      "post": {
        "tags": [
          "OCR"
        ],
        "summary": "This is a Async API to extract key values from the given document and predicts the Type of the fields",
        "consumes": [
          "multipart/form-data"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "pageNo",
            "description": "PageNo eg. for pdf with Page size 10, values could be 1,2,3 or 1-3 or 1, 3-5  or  1-3, 7-10",
