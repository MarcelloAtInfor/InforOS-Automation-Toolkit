          },
          {
            "in": "path",
            "name": "ver",
            "required": true,
            "type": "string"
          },
          {
            "in": "formData",
            "name": "ocrDocument",
            "description": "Document path that needs to be OCR",
            "type": "file"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/ocrsvc/v{ver}/AysncTemplateExtraction": {
      "post": {
        "tags": [
          "OCR"
        ],
        "summary": "This is a Async API to Extract data from the Document, based on the selected template.",
        "consumes": [
          "multipart/form-data"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "documentType",
            "description": "Name of the document type which is uploaded eg. Invoice",
            "type": "string"
          },
          {
            "in": "path",
            "name": "ver",
            "required": true,
            "type": "string"
          },
          {
            "in": "formData",
            "name": "ocrDocument",
            "description": "Document path from which data needs to be extracted",
            "type": "file"
          },
          {
            "in": "formData",
            "name": "templateFile",
            "description": "Template path which would be applied on the document to extract data",
            "type": "file"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/ocrsvc/v{ver}/AsyncDocumentKeyValue": {
      "post": {
        "tags": [
          "OCR"
        ],
        "summary": "This is a Async API to returns the values for the requested keys",
        "consumes": [
          "multipart/form-data"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "list_of_keys",
            "description": "Comma seperated list of keys to search",
            "type": "string"
          },
          {
            "in": "query",
            "name": "pageNo",
            "description": "PageNo eg. for pdf with Page size 10, values could be 1,2,3 or 1-3 or 1, 3-5  or  1-3, 7-10",
            "type": "string"
          },
          {
            "in": "path",
            "name": "ver",
            "required": true,
