{
  "swagger": "2.0",
  "info": {
    "title": "Infor Document Processor",
    "version": "v1"
  },
  "host": "mingle-ionapi.inforcloudsuite.com",
  "basePath": "/<YOUR_TENANT>/COLEMANDDP",
  "schemes": [
    "https"
  ],
  "paths": {
    "/ocrsvc/v{ver}/DocumentProcessorFlows/{documentProcessorFlowGuid}/Job": {
      "post": {
        "tags": [
          "Modelling"
        ],
        "summary": "Create Job for Document Processor flow",
        "operationId": "CreateJob",
        "consumes": [
          "multipart/form-data"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "documentProcessorFlowGuid",
            "description": "",
            "required": true,
            "type": "string"
          },
          {
            "in": "query",
            "name": "pageNo",
            "description": "PageNo eg. for pdf with Page size 10, values could be 1,2,3 or 1-3 or 1, 3-5  or  1-3, 7-10",
            "type": "string"
          },
          {
            "in": "query",
            "name": "ocrProviderID",
            "description": "OCRProvider, The Default value will be picked based on the region",
            "type": "string",
            "default": ""
          },
          {
            "in": "path",
            "name": "ver",
            "required": true,
            "type": "string"
          },
          {
            "in": "formData",
            "name": "document",
            "description": "",
            "type": "file"
          },
          {
            "in": "formData",
            "name": "modelID",
            "description": "ModelID for Inference please refer to documention for modelID, The default value will picked based on the region",
            "type": "string"
          },
          {
            "in": "formData",
            "name": "geometryRequired",
            "description": "True/False if Geometry of words is needed",
            "type": "boolean",
            "default": false
          },
          {
            "in": "formData",
            "name": "confidenceRequired",
            "description": "True/Fase if Confidence of the Inference needs to be returned as part of output",
            "type": "boolean",
            "default": false
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/ocrsvc/v{ver}/Jobs/List": {
      "post": {
        "tags": [
          "Modelling"
        ],
        "consumes": [
          "application/json-patch+json",
          "application/json",
          "text/json",
          "application/*+json"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "ver",
            "required": true,
            "type": "string"
          },
          {
            "in": "body",
            "name": "body",
            "schema": {
              "$ref": "#/definitions/GridFilters"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/ocrsvc/v{ver}/Jobs/{jobId}": {
      "get": {
        "tags": [
          "Modelling"
        ],
        "summary": "Get the result for the Job ID",
        "parameters": [
          {
            "in": "path",
            "name": "jobId",
            "required": true,
            "type": "string"
          },
          {
            "in": "query",
            "name": "isPathRequired",
            "description": "",
            "type": "boolean",
            "default": false
          },
          {
            "in": "path",
            "name": "ver",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "202": {
            "description": "Accepted"
          }
        }
      }
    },
    "/ocrsvc/v{ver}/Models/List": {
      "get": {
        "tags": [
          "Modelling"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "ver",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/ocrsvc/v{ver}/OCRProviders/List": {
      "get": {
        "tags": [
          "OCR"
        ],
        "summary": "Get the OCR Providers",
        "parameters": [
          {
            "in": "path",
            "name": "ver",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/ocrsvc/v{ver}/DocumentOCR": {
      "post": {
        "tags": [
          "OCR"
        ],
        "summary": "This API does OCR of the given Document",
        "consumes": [
          "multipart/form-data"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "ver",
            "required": true,
            "type": "string"
          },
          {
            "in": "formData",
            "name": "ocrDocument",
            "description": "Document path that needs to be OCR",
            "type": "file"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/ocrsvc/v{ver}/TemplateExtraction": {
      "post": {
        "tags": [
          "OCR"
        ],
        "summary": "This API Extract data from the Document, based on the selected template.",
        "consumes": [
          "multipart/form-data"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "documentType",
            "description": "Name of the document type which is uploaded eg. Invoice",
            "type": "string"
          },
          {
            "in": "path",
            "name": "ver",
            "required": true,
            "type": "string"
          },
          {
            "in": "formData",
            "name": "ocrDocument",
            "description": "Document path from which data needs to be extracted",
            "type": "file"
          },
          {
            "in": "formData",
            "name": "templateFile",
            "description": "Template path which would be applied on the document to extract data",
            "type": "file"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/ocrsvc/v{ver}/DocumentKeyValue": {
      "post": {
        "tags": [
          "OCR"
        ],
        "summary": "This API returns the values for the requested keys",
