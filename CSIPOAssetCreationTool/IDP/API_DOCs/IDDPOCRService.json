    "/ocrsvc/v{ver}/GetJobResult": {
      "post": {
        "tags": [
          "OCR"
        ],
        "summary": "This API returns the Job result for a given JobID",
        "parameters": [
          {
            "in": "query",
            "name": "taskID",
            "description": "The JobID of the Job",
            "type": "string"
          },
          {
            "in": "query",
            "name": "isPathRequired",
            "type": "boolean",
            "default": false
          },
          {
            "in": "path",
            "name": "ver",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "202": {
            "description": "Accepted"
          }
        }
      }
    },
    "/ocrsvc/v{ver}/DocumentExtraction": {
      "post": {
        "tags": [
          "OCR"
        ],
        "summary": "This API extract key values from the given document and predicts the Type for the fields",
        "consumes": [
          "multipart/form-data"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "ver",
            "required": true,
            "type": "string"
          },
          {
            "in": "formData",
            "name": "doc_to_analyze",
            "description": "The document to be extracted",
