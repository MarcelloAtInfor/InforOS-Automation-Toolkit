        ],
        "summary": "Returns a list of active workflows and their interface information.",
        "description": "Returns a JSON structure with the list of all active workflows with information about their defined input and output variables and structures.",
        "operationId": "getWorkflowInterfaces",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "description": "The workflow definition name (optional)",
            "required": false,
