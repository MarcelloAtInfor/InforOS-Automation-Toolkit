{
  "swagger": "2.0",
  "info": {
    "description": "This interface can be used to access ION Process functionality for application to application integration. All datetime strings are in ISO 8601 format, Serialization of properties with null values is suppressed. This API has the throttling feature enabled, it may return error 429 when the quota (10 calls per 10 seconds) is exceeded. Some fields in the request body are restricted by length, it may return error 400 when length exceeds the limit. These length validations are similar as in the user interface and are described in the Infor ION Desk User Guide.",
    "version": "2026.01, build 9",
    "title": "ION Process Application Rest API"
  },
  "basePath": "/<YOUR_TENANT>/IONSERVICES/process/application",
  "tags": [
    {
      "name": "Generic"
    },
    {
      "name": "Pulse"
    },
    {
      "name": "Workflow"
    }
  ],
  "paths": {
    "/ping": {
      "get": {
        "tags": [
          "Generic"
        ],
        "summary": "Ping the REST interface.",
        "description": "Can be used as Status/health method to validate the connection.",
        "operationId": "ping",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/v1/pulse/alert/cancel": {
      "post": {
        "tags": [
          "Pulse"
        ],
        "summary": "Cancels an Alert",
        "description": "Method to cancel a Pulse Alert with source type API and source name as the specified application logicalId",
        "operationId": "cancelAlert",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "logicalId",
            "in": "query",
            "description": "The application logicalId",
            "required": true,
            "type": "string"
          },
          {
            "in": "body",
            "name": "activityCancelJSONBody",
            "description": "Details for the alert to be cancelled represented as JSON",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ActivityCancel"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Item Cancelled",
            "schema": {
              "$ref": "#/definitions/Activity"
            }
          },
          "400": {
            "description": "Bad Request, missing or invalid input"
          },
          "404": {
            "description": "Not found"
          },
          "409": {
            "description": "Status conflict"
          },
          "500": {
            "description": "Server Error"
          }
        }
      }
    },
    "/v1/pulse/alert/create": {
      "post": {
        "tags": [
          "Pulse"
        ],
        "summary": "Creates a new Alert",
        "description": "Creates a new Pulse Alert with source type API and source name as the specified application logicalId",
        "operationId": "createAlert",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "logicalId",
            "in": "query",
            "description": "The application logicalId",
            "required": true,
            "type": "string"
          },
          {
            "in": "body",
            "name": "alertJSONBody",
            "description": "The Alert details and distribution list represented as JSON",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Alert"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Item created",
            "schema": {
              "$ref": "#/definitions/Activity"
            }
          },
          "400": {
            "description": "Bad Request, missing or invalid input"
          },
          "500": {
            "description": "Server Error"
          }
        }
      }
    },
    "/v1/pulse/alert/redistribute": {
      "post": {
        "tags": [
          "Pulse"
        ],
        "summary": "Redistribute an Alert",
        "description": "Method to redistribute a Pulse Alert to a new distribution list. You can specify action REPLACE if the new distribution list should replace the current list, or action ADD if the new distribution list should be added to the current list. If not specified, the REPLACE action is executed.",
        "operationId": "redistributeAlert",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "logicalId",
            "in": "query",
            "description": "The application logicalId",
            "required": true,
            "type": "string"
          },
          {
            "in": "body",
            "name": "redistributeJSONBody",
            "description": "Details for the alert to be redistributed represented as JSON",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Redistribution"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Item redistributed",
            "schema": {
              "$ref": "#/definitions/Activity"
            }
          },
          "400": {
            "description": "Bad Request, missing or invalid input"
          },
          "404": {
            "description": "Not found"
          },
          "409": {
            "description": "Status conflict"
          },
          "500": {
            "description": "Server Error"
          }
        }
      }
    },
