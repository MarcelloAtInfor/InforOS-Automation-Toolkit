  "definitions": {
    "ActionButton": {
      "type": "object",
      "required": [
        "label",
        "value"
      ],
      "properties": {
        "label": {
          "type": "string",
          "description": "Action button label"
        },
        "value": {
          "type": "string",
          "description": "Action button variable value"
        }
      }
    },
    "Activity": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "format": "int64",
          "description": "Id of the created or handeled Pulse Item"
        }
      }
    },
    "ActivityCancel": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "format": "int64",
          "description": "Id of the item to cancel"
        }
      }
    },
    "Alert": {
      "type": "object",
      "required": [
        "distribution",
        "message"
      ],
      "properties": {
        "message": {
          "type": "string",
          "description": "Alert message"
        },
        "category": {
          "type": "string",
          "description": "Can be used to set the Alert category"
        },
        "alertDateTime": {
          "type": "string",
          "example": "2017-03-22T12:03:19Z",
          "description": "Timestamp when the Alert occurred in ISO8601 date&time format (UTC)"
        },
        "dueDate": {
          "type": "string",
          "example": "2017-03-22T12:03:19Z",
          "description": "Alert due date in ISO8601 date&time format (UTC)"
        },
        "details": {
          "description": "The Alert detail tree",
          "$ref": "#/definitions/TreeLevel"
        },
        "views": {
          "type": "array",
          "description": "List of drillback views",
          "items": {
            "$ref": "#/definitions/View"
          }
        },
        "distribution": {
          "type": "array",
          "description": "List of distributions formed of user identifiers or group names",
          "items": {
            "$ref": "#/definitions/Distribution"
          }
        },
        "translations": {
          "type": "object",
          "description": "Mapping of language code to translation, language code is in (ISO 639-ISO 3166) format, some examples: 'en-US' for English (United States) and 'nl-NL' for Dutch (Netherlands). See also RFC 5646.",
          "additionalProperties": {
            "$ref": "#/definitions/AlertTranslation"
          }
        }
      }
    },
    "AlertTranslation": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "description": "translated message"
        },
        "viewLabels": {
          "type": "object",
          "description": "Mapping of view name to label translations",
          "additionalProperties": {
            "type": "string"
          }
        },
        "category": {
          "type": "string",
          "description": "translated category"
        }
      }
    },
    "CustomActions": {
      "type": "object",
      "properties": {
        "parameterName": {
          "type": "string",
          "description": "The name of the parameter that will contain the selected action button"
        },
        "buttons": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ActionButton"
          }
        }
      }
    },
    "Distribution": {
      "type": "object",
      "required": [
        "identifier",
        "type"
      ],
      "properties": {
        "identifier": {
          "type": "string",
          "description": "The identifier of a user or group. A user is identified by the IFS Identity2. A group is identified by an IFS Distribution Group name."
        },
        "type": {
          "type": "string",
          "description": "The Distribution type",
          "enum": [
            "USER",
            "GROUP"
          ]
        },
        "sendMail": {
          "type": "boolean",
          "description": "Indicator if an email notification should be sent to this Distribution"
        }
      }
    },
    "Notification": {
      "type": "object",
      "required": [
        "distribution",
        "message"
      ],
      "properties": {
        "message": {
          "type": "string",
          "description": "Notification message"
        },
        "category": {
          "type": "string",
          "description": "Can be used to set the Notification category"
        },
        "contextId": {
          "type": "integer",
          "format": "int64",
          "description": "The Notification context identifier (for instance, the workflow instance id)"
        },
        "subContextId": {
          "type": "integer",
          "format": "int64",
          "description": "The Notification subcontext identifier (for instance, the workflow step id)"
        },
        "retention": {
          "type": "integer",
          "format": "int32",
          "example": 30,
          "description": "The Notification retention time in days (30, 60 or 90 days)"
        },
        "parameters": {
          "type": "array",
          "description": "The Notification parameters",
          "items": {
            "$ref": "#/definitions/Parameter"
          }
        },
        "views": {
          "type": "array",
          "description": "List of drillback views",
          "items": {
            "$ref": "#/definitions/View"
          }
        },
        "distribution": {
          "type": "array",
          "description": "List of distributions formed of user identifiers or group names",
          "items": {
            "$ref": "#/definitions/Distribution"
          }
        },
        "translations": {
          "type": "object",
          "description": "Mapping of language code to translation, language code is in (ISO 639-ISO 3166) format, some examples: 'en-US' for English (United States) and 'nl-NL' for Dutch (Netherlands). See also RFC 5646.",
          "additionalProperties": {
            "$ref": "#/definitions/Translation"
          }
        }
      }
    },
    "Parameter": {
      "type": "object",
      "required": [
        "dataType",
        "name",
        "value"
      ],
      "properties": {
        "dataType": {
          "type": "string",
          "description": "The datatype of this Parameter",
          "enum": [
            "STRING",
            "INTEGER",
            "DECIMAL",
            "BOOLEAN",
            "DATETIME",
            "DATE"
          ]
        },
        "name": {
          "type": "string",
          "description": "The name of this Parameter"
        },
        "value": {
          "type": "string",
          "description": "Value as a String based on the Datatype"
        },
        "label": {
          "type": "string",
          "description": "Label for the parameter. If a label is not set, the parameter name is used"
        },
        "readOnly": {
          "type": "boolean",
          "description": "Indicator if the value is read-only. If not specified the value is true. It is ignored for Pulse Notification as all Parameters are read-only"
        }
      }
    },
    "Redistribution": {
      "type": "object",
      "required": [
        "distribution"
      ],
      "properties": {
        "id": {
          "type": "integer",
          "format": "int64",
          "description": "Id of the Pulse Item to redistribute"
        },
        "action": {
          "type": "string",
          "description": "The optional action, values can be REPLACE or ADD, if not specified the action is REPLACE",
          "enum": [
            "REPLACE",
            "ADD"
          ]
        },
        "distribution": {
          "type": "array",
          "description": "List of distributions formed of user identifiers or group names",
          "items": {
            "$ref": "#/definitions/Distribution"
          }
        }
      }
    },
    "StartWorkflowRequest": {
      "type": "object",
      "required": [
        "instanceName",
        "workflowName"
      ],
      "properties": {
        "workflowName": {
          "type": "string",
          "description": "The name of the Workflow to start"
        },
        "instanceName": {
          "type": "string",
          "description": "The name/description for this specific Workflow instance"
        },
        "inputVariables": {
          "type": "array",
          "description": "The set of variables to use as input for the new Workflow instance",
          "items": {
            "$ref": "#/definitions/WorkflowVariable"
          }
        },
        "inputStructures": {
          "type": "array",
          "description": "The set of structures to use as input for the new Workflow instance",
          "items": {
            "$ref": "#/definitions/Structure"
          }
        }
      }
    },
    "StartWorkflowResult": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "format": "int64",
          "description": "The identifier of the started Workflow instance"
        }
      }
    },
    "Structure": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of this structure"
        },
        "fields": {
          "type": "array",
          "description": "List of fields",
          "items": {
            "$ref": "#/definitions/StructureField"
          }
        },
        "subStructures": {
          "type": "array",
          "description": "List of sub structures",
          "items": {
            "$ref": "#/definitions/Structure"
          }
        }
      }
    },
    "StructureField": {
      "type": "object",
      "required": [
        "dataType",
        "name",
        "value"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of this structure field"
        },
        "dataType": {
          "type": "string",
          "description": "The datatype of this structure field",
          "enum": [
            "STRING",
            "INTEGER",
            "DECIMAL",
            "BOOLEAN",
            "DATETIME",
            "DATE"
          ]
        },
        "value": {
          "type": "string",
