    "/load/{ido}": {
      "get": {
        "tags": [
          "IDO"
        ],
        "summary": "LoadCollection",
        "description": "Returns a set of records from a collection",
        "operationId": "loadCollection",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": false,
            "description": "Token obtained through a call to SecurityToken, or if using the service through ION API, a valid OAuth 2.0 Bearer token (filled in automatically by Swagger UI).",
            "type": "string"
          },
          {
            "name": "X-Infor-MongooseConfig",
            "in": "header",
            "required": false,
            "description": "Mongoose configuration to log into; required when using the service through ION API, not needed otherwise.",
            "type": "string"
          },
          {
            "name": "ido",
            "in": "path",
            "required": true,
            "description": "IDO name",
            "type": "string"
          },
          {
            "name": "properties",
            "in": "query",
            "required": true,
            "description": "A comma-delimited property list. Provide '*' to include all, except subcollection properties.",
            "type": "array",
            "items": {
              "type": "string",
              "collectionFormat": "csv"
            }
          },
          {
            "name": "filter",
            "in": "query",
            "required": false,
            "description": "SQL filter string",
            "type": "string"
          },
          {
            "name": "orderBy",
            "in": "query",
            "required": false,
            "description": "SQL ORDER BY value",
            "type": "string"
          },
          {
            "name": "recordCap",
            "in": "query",
            "required": false,
            "description": "Sets row cap: -1 = default in Mongoose; 0 = unlimited.",
            "type": "integer"
          },
          {
            "name": "distinct",
            "in": "query",
            "required": false,
            "description": "SQL DISTINCT keyword",
            "type": "boolean"
          },
          {
            "name": "clm",
            "in": "query",
            "required": false,
            "description": "Custom Load Method name",
            "type": "string"
          },
          {
            "name": "clmParam",
            "in": "query",
            "required": false,
            "description": "Comma-separated Custom Load Method parameters",
            "type": "array",
            "items": {
              "collectionFormat": "csv"
            }
          },
          {
            "name": "loadType",
            "in": "query",
            "required": false,
            "description": "Load type, one of FIRST | NEXT | PREVIOUS | LAST",
            "type": "string",
            "enum": [
              "FIRST",
              "NEXT",
              "PREVIOUS",
              "LAST"
            ]
          },
          {
            "name": "bookmark",
            "in": "query",
            "required": false,
            "description": "Designate bookmark ID",
            "type": "string"
          },
          {
            "name": "pqc",
            "in": "query",
            "required": false,
            "description": "Post Query Command name",
            "type": "string"
          },
          {
            "name": "readOnly",
            "in": "query",
            "required": false,
            "description": "Read Only flag; if set to 'true', no ItemId is returned with query",
            "type": "boolean"
          }
        ],
        "responses": {
          "200": {
            "description": "See Success and Message in the response for result status.",
            "schema": {
              "$ref": "#/definitions/LoadCollectionResponse"
            }
          },
          "401": {
            "$ref": "#/responses/Unauthorized"
          }
        }
      }
    },
